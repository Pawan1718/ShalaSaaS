@using MudBlazor

<MudPaper Class="pa-3 report-metric-card" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Title</MudText>
            <MudText Typo="Typo.h6">@Value</MudText>
        </div>
        <MudAvatar Color="Color" Variant="Variant.Filled" Size="Size.Medium">
            <MudIcon Icon="@Icon" />
        </MudAvatar>
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Analytics;
    [Parameter] public Color Color { get; set; } = Color.Primary;
}
