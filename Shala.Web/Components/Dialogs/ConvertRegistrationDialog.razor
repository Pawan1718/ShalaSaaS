@using MudBlazor
@using Shala.Shared.Requests.Registration
@using Shala.Shared.Responses.Registration
@using Shala.Shared.Responses.Students
@using Shala.Web.Repositories.Interfaces
@using Shala.Web.Services.State

@inject IStudentLookupRepository StudentLookupRepository
@inject ApiSession Session
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        Convert Registration
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true">
                    <div><strong>Student:</strong> @GetStudentName()</div>
                    <div><strong>Registration No:</strong> @GetRegistrationNo()</div>
                </MudAlert>
            </MudItem>

            @if (_loading)
            {
                <MudItem xs="12">
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Loading academic year and class...
                    </MudText>
                </MudItem>
            }

            <MudItem xs="12" md="6">
                <MudDatePicker Label="Admission Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Date="_admissionDate"
                               DateChanged="OnAdmissionDateChanged"
                               Editable="true"
                               Disabled="_loading" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?"
                           Label="Academic Year"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           @bind-Value="_model.AcademicYearId"
                           Required="true"
                           Disabled="_loading">
                    @foreach (var item in _academicYears)
                    {
                        <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?"
                           Label="Class"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="_model.ClassId"
                           ValueChanged="OnClassChanged"
                           Required="true"
                           Disabled="_loading">
                    @foreach (var item in _classes)
                    {
                        <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_submitting">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SubmitAsync"
                   Disabled="@(_loading || _submitting)">
            Convert
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public RegistrationDto Model { get; set; } = new();

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private ConvertRegistrationRequest _model = new();
    private DateTime? _admissionDate = DateTime.Today;

    private List<LookupItemResponse> _academicYears = new();
    private List<LookupItemResponse> _classes = new();

    private bool _loading;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        await InitializeLookupDataAsync();
    }

    private async Task InitializeLookupDataAsync()
    {
        if (_loading)
            return;

        try
        {
            _loading = true;

            await Session.InitializeAsync();

            if (!Session.TenantId.HasValue || !Session.BranchId.HasValue)
            {
                Snackbar.Add("Tenant/Branch context missing.", Severity.Error);
                return;
            }

            _model = new ConvertRegistrationRequest
            {
                AdmissionDate = DateTime.Today
            };

            _admissionDate = _model.AdmissionDate;

            var academicYearTask = StudentLookupRepository.GetAcademicYearsAsync(Session.TenantId.Value);
            var classTask = StudentLookupRepository.GetClassesAsync(Session.TenantId.Value);

            await Task.WhenAll(academicYearTask, classTask);

            var academicYearResponse = await academicYearTask;
            var classResponse = await classTask;

            _academicYears = academicYearResponse?.Success == true && academicYearResponse.Data is not null
                ? academicYearResponse.Data
                : new List<LookupItemResponse>();

            _classes = classResponse?.Success == true && classResponse.Data is not null
                ? classResponse.Data
                : new List<LookupItemResponse>();

            _model.AcademicYearId = ResolveDefaultAcademicYearId();
            _model.ClassId = ResolveDefaultClassId();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private int? ResolveDefaultAcademicYearId()
    {
        if (_academicYears.Count == 0)
            return null;

        return _academicYears.First().Id;
    }

    private int? ResolveDefaultClassId()
    {
        if (_classes.Count == 0)
            return null;

        if (Model.InterestedClassId > 0 && _classes.Any(x => x.Id == Model.InterestedClassId))
            return Model.InterestedClassId;

        return _classes.First().Id;
    }

    private Task OnClassChanged(int? classId)
    {
        _model.ClassId = classId;
        return InvokeAsync(StateHasChanged);
    }

    private void OnAdmissionDateChanged(DateTime? value)
    {
        _admissionDate = value ?? DateTime.Today;
        _model.AdmissionDate = _admissionDate;
    }

    private async Task SubmitAsync()
    {
        if (_submitting)
            return;

        try
        {
            _submitting = true;
            _model.AdmissionDate = _admissionDate ?? DateTime.Today;

            if (!_model.AcademicYearId.HasValue)
            {
                Snackbar.Add("Please select academic year.", Severity.Warning);
                return;
            }

            if (!_model.ClassId.HasValue)
            {
                Snackbar.Add("Please select class.", Severity.Warning);
                return;
            }

            MudDialog.Close(DialogResult.Ok(_model));
        }
        finally
        {
            _submitting = false;
        }
    }

    private string GetStudentName()
    {
        return string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName;
    }

    private string GetRegistrationNo()
    {
        return string.IsNullOrWhiteSpace(Model.RegistrationNo) ? "-" : Model.RegistrationNo;
    }

    private void Cancel() => MudDialog.Cancel();
}