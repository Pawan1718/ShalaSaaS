@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests
@using Shala.Shared.Requests.Platform
@using Shala.Web.Components.Common
@using Shala.Web.Repositories
@using Shala.Web.Repositories.PlatformRepo

@inject ITenantRepository TenantRepository
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <AppError Message="@_errorMessage" Class="mb-3" />
        }

        <AppTextField @bind-Value="_model.NewPassword"
                      Label="New Password"
                      Placeholder="Enter new password"
                      IsPassword="true"
                      Required="true"
                      RequiredError="Password is required"
                      HelperText="Use a strong password for the tenant admin account."
                      autocomplete="new-password" />
    </DialogContent>

    <DialogActions>
        <AppButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="CancelClickAsync"
                   Disabled="_isSubmitting">
            Cancel
        </AppButton>

        <AppButton OnClick="SubmitClickAsync"
                   Color="Color.Primary"
                   Disabled="_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                <span>Resetting...</span>
            }
            else
            {
                <span>Reset Password</span>
            }
        </AppButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int TenantId { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private ResetTenantAdminPasswordRequest _model = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    private async Task SubmitClickAsync(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(_model.NewPassword))
        {
            _errorMessage = "Password is required.";
            Snackbar.Add(_errorMessage, Severity.Error);
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var response = await TenantRepository.ResetTenantAdminPasswordAsync(TenantId, _model);

            if (response.IsSuccess)
            {
                Snackbar.Add("Password reset successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var body = await response.GetBodyPartAsync();
                _errorMessage = string.IsNullOrWhiteSpace(body)
                    ? "Failed to reset password"
                    : body;

                Snackbar.Add(_errorMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task CancelClickAsync(MouseEventArgs _)
    {
        MudDialog.Cancel();
        await Task.CompletedTask;
    }
}