@using MudBlazor
@using Shala.Shared.Responses.Fees

<MudStack Spacing="2">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
      

        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success">
                Receipts: @Receipts.Count()
            </MudChip>
            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary">
                Total: @Receipts.Sum(x => x.TotalAmount).ToString("N2")
            </MudChip>
        </MudStack>
    </MudStack>

    @if (!Receipts.Any())
    {
        <MudPaper Class="pa-6" Outlined="true" Style="border-radius:16px;">
            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Success">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                </MudAvatar>
                <MudText Typo="Typo.subtitle1">No receipts recorded yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                    Receipt entries will appear here once fee collection is recorded.
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudTable Items="Receipts"
                  Dense="false"
                  Hover="true"
                  Bordered="false"
                  Striped="false"
                  Elevation="0"
                  Breakpoint="Breakpoint.Sm"
                  Class="receipts-modern-table">

            <HeaderContent>
                <MudTh>Receipt</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Payment Mode</MudTh>
                <MudTh>Reference</MudTh>
                <MudTh>Remarks</MudTh>
                <MudTh class="text-end">Amount</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="Receipt">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@context.ReceiptNo</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @GetReceiptHint(context)
                        </MudText>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="Date">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@context.ReceiptDate.ToString("dd MMM yyyy")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.ReceiptDate.ToString("hh:mm tt")
                        </MudText>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="Payment Mode">
                    <MudChip T="string"
                             Variant="Variant.Filled"
                             Size="Size.Small"
                             Color="@GetPaymentModeColor(context.PaymentMode)">
                        @GetPaymentModeText(context.PaymentMode)
                    </MudChip>
                </MudTd>

                <MudTd DataLabel="Reference">
                    <MudText Typo="Typo.body2">
                        @(string.IsNullOrWhiteSpace(context.TransactionReference) ? "-" : context.TransactionReference)
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Remarks">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @(string.IsNullOrWhiteSpace(context.Remarks) ? "-" : context.Remarks)
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Amount" class="text-end">
                    <MudText Typo="Typo.subtitle2" Color="Color.Success">
                        @context.TotalAmount.ToString("N2")
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

<style>
    .receipts-modern-table {
        border-radius: 18px;
        overflow: hidden;
        background: var(--mud-palette-surface);
    }

        .receipts-modern-table .mud-table-head {
            background: rgba(46, 125, 50, 0.08);
        }

            .receipts-modern-table .mud-table-head th {
                font-weight: 600;
                white-space: nowrap;
            }

        .receipts-modern-table .mud-table-body tr:hover {
            background: rgba(46, 125, 50, 0.04);
        }

        .receipts-modern-table .mud-table-body td {
            vertical-align: top;
            padding-top: 14px;
            padding-bottom: 14px;
        }
</style>

@code {
    [Parameter]
    public IEnumerable<FeeReceiptResponse> Receipts { get; set; } = Enumerable.Empty<FeeReceiptResponse>();

    private static string GetReceiptHint(FeeReceiptResponse receipt)
    {
        var allocations = receipt.Allocations?.Count ?? 0;
        return allocations > 0
            ? $"{allocations} allocation(s)"
            : "Payment recorded";
    }

    private static string GetPaymentModeText(int paymentMode) => paymentMode switch
    {
        1 => "Cash",
        2 => "UPI",
        3 => "Bank Transfer",
        4 => "Cheque",
        5 => "Card",
        _ => "Other"
    };

    private static Color GetPaymentModeColor(int paymentMode) => paymentMode switch
    {
        1 => Color.Success,
        2 => Color.Primary,
        3 => Color.Info,
        4 => Color.Warning,
        5 => Color.Secondary,
        _ => Color.Default
    };
}