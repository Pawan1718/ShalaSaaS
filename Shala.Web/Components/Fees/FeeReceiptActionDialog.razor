@using MudBlazor
@using Microsoft.JSInterop
@using Shala.Web.Models.Fees
@using Shala.Shared.Responses.Settings
@using Shala.Web.Components.Fees

<MudDialog MaxWidth="MaxWidth.ExtraLarge" FullWidth="true">
    <TitleContent>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%;">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Fee Receipt</MudText>
            </MudStack>

            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                @(Model?.ReceiptNo ?? "-")
            </MudChip>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (Model is null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                Receipt preview is not available.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="3">
                <MudPaper Class="pa-3" Outlined="true" Style="border-radius:16px;">
                    <MudStack Row="true"
                              Justify="Justify.SpaceBetween"
                              AlignItems="AlignItems.Center"
                              Wrap="Wrap.Wrap">
                        <div>
                            <MudText Typo="Typo.subtitle1">Print Preview</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Review and print receipt.
                            </MudText>
                        </div>

                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Disabled="@(Model is null || !(Profile?.AllowDownloadReceipt ?? true))"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       OnClick="Download">
                                Download
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@(Model is null || !(Profile?.AllowPrintReceipt ?? true))"
                                       StartIcon="@Icons.Material.Filled.Print"
                                       OnClick="Print">
                                Print
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <FeeReceiptCanvas TargetId="fee-receipt"
                                  Receipt="Model"
                                  Profile="Profile"
                                  RootCssClass="receipt-preview-root" />
            </MudStack>
        }
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Close">
            Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public FeeReceiptPrintVm? Model { get; set; }
    [Parameter] public BranchDocumentProfileResponse? Profile { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private void Close()
    {
        MudDialog.Close();
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("feeReceipt.printElement", "fee-receipt");
    }

    private async Task Download()
    {
        await JS.InvokeVoidAsync("feeReceipt.downloadPdf", "fee-receipt");
    }
}