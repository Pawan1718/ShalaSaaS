@using MudBlazor

<MudContainer MaxWidth="@MaxWidth" Class="@BuildClass()">
    @ChildContent
</MudContainer>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public MaxWidth MaxWidth { get; set; } = MaxWidth.ExtraLarge;
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public string PaddingClass { get; set; } = "pa-4 pa-md-6";

    private string BuildClass() => $"{PaddingClass} {Class}".Trim();
}