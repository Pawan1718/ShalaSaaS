@using MudBlazor

<MudStack AlignItems="AlignItems.Center"
          Justify="Justify.Center"
          Class="pa-6 text-center">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="@IconColor" Class="mb-2" />
    <MudText Typo="Typo.h6">@Title</MudText>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @Message
        </MudText>
    }

    @if (Actions is not null)
    {
        <div class="mt-4">
            @Actions
        </div>
    }
</MudStack>

@code {
    [Parameter] public string Title { get; set; } = "No data found";
    [Parameter] public string? Message { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public Color IconColor { get; set; } = Color.Default;
    [Parameter] public RenderFragment? Actions { get; set; }
}