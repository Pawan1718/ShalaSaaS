@using MudBlazor

<MudPaper Class="@BuildClass()"
          Elevation="@Elevation"
          Style="@Style">
    @ChildContent
</MudPaper>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int Elevation { get; set; } = 2;
    [Parameter] public string PaddingClass { get; set; } = "pa-4";
    [Parameter] public string RadiusClass { get; set; } = "rounded-lg";
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private string BuildClass()
        => $"{PaddingClass} {RadiusClass} {Class}".Trim();
}