@using Shala.Shared.Responses.Registration
@using Shala.Shared.Responses.Settings

<div id="@TargetId" class="receipt-print-root @RootCssClass">
    @if (Mode == ReceiptCanvasMode.DualA4)
    {
        <div class="a4-sheet">
            <RegistrationReceiptTemplate Receipt="Receipt"
                                         Profile="Profile"
                                         ShowCopyLabel="true"
                                         CopyLabel="Parent Copy"
                                         CopyCssClass="parent-copy" />

            <div class="cut-line-wrap" aria-hidden="true">
                <div class="cut-icon-row">
                    <span>✂</span>
                    <span>✂</span>
                </div>
                <div class="cut-line"></div>
            </div>

            <RegistrationReceiptTemplate Receipt="Receipt"
                                         Profile="Profile"
                                         ShowCopyLabel="true"
                                         CopyLabel="School Copy"
                                         CopyCssClass="school-copy" />
        </div>
    }
    else
    {
        <div class="receipt-preview-shell">
            <RegistrationReceiptTemplate Receipt="Receipt"
                                         Profile="Profile"
                                         ShowCopyLabel="false"
                                         CopyCssClass="" />
        </div>
    }
</div>

@code {
    [Parameter] public string TargetId { get; set; } = "registration-receipt";
    [Parameter] public RegistrationReceiptResponse? Receipt { get; set; }
    [Parameter] public BranchDocumentProfileResponse? Profile { get; set; }
    [Parameter] public ReceiptCanvasMode Mode { get; set; } = ReceiptCanvasMode.SinglePreview;
    [Parameter] public string RootCssClass { get; set; } = "";
}