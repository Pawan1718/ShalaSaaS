@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using Shala.Shared.Responses.StudentDocument
@using Shala.Web.Repositories.StudentDocuments

@inject IStudentDocumentWebRepository Repo
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">
                    @_error
                </MudAlert>
            }

            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <MudSelect T="int?"
                               Label="Document Model"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               FullWidth="true"
                               Disabled="_saving"
                               @bind-Value="_selectedDocumentModelId">
                        @foreach (var item in DocumentModels.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Name))
                        {
                            <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Title"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  Disabled="_saving"
                                  @bind-Value="_title" />
                </MudItem>

                <MudItem xs="12">
                    <MudSwitch T="bool"
                               @bind-Value="_isRequired"
                               Disabled="_saving"
                               Color="Color.Primary"
                               Label="Required for this student" />
                </MudItem>

                <MudItem xs="12">
                    <InputFile OnChange="OnFileSelected" disabled="@_saving" />
                    @if (_file is not null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">
                            Selected: @_file.Name (@GetFileSizeInKb(_file.Size) KB)
                        </MudText>
                    }
                </MudItem>
            </MudGrid>

            <MudItem xs="12">
                @if (_saving)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        File selection disabled while uploading.
                    </MudText>
                }
                else
                {
                    <InputFile OnChange="OnFileSelected" />
                }

                @if (_file is not null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">
                        Selected: @_file.Name (@GetFileSizeInKb(_file.Size) KB)
                    </MudText>
                }
            </MudItem>
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="Cancel"
                   Disabled="_saving">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SaveAsync"
                   Disabled="_saving || !_selectedDocumentModelId.HasValue || _file is null">
            @(_saving ? "Uploading..." : "Upload")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int StudentId { get; set; }
    [Parameter] public List<DocumentModelResponse> DocumentModels { get; set; } = new();

    private int? _selectedDocumentModelId;
    private string _title = string.Empty;
    private bool _isRequired;
    private IBrowserFile? _file;
    private bool _saving;
    private string? _error;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _error = null;
    }

    private async Task SaveAsync()
    {
        if (_saving)
            return;

        _error = null;

        if (!_selectedDocumentModelId.HasValue)
        {
            _error = "Please select a document model.";
            return;
        }

        if (_file is null)
        {
            _error = "Please select a file.";
            return;
        }

        var model = DocumentModels.FirstOrDefault(x => x.Id == _selectedDocumentModelId.Value);
        if (model is null)
        {
            _error = "Selected document model not found.";
            return;
        }

        _saving = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var request = new UploadStudentDocumentWebRequest
            {
                StudentId = StudentId,
                DocumentModelId = model.Id,
                DocumentType = model.Code,
                Title = string.IsNullOrWhiteSpace(_title) ? model.Name : _title.Trim(),
                IsRequired = _isRequired || model.IsRequired,
                File = _file
            };

            await Repo.UploadAsync(request);

            Snackbar.Add("Document uploaded successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetFileSizeInKb(long bytes)
    {
        return (bytes / 1024.0).ToString("0.##");
    }

    private void Cancel()
    {
        if (_saving)
            return;

        MudDialog.Cancel();
    }
}