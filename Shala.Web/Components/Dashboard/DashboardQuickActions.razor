@using Shala.Web.Components.Common
<MudGrid Class="mt-4" Spacing="2">

    <MudItem xs="12" md="3">
        <AppButton FullWidth="true" OnClick="@(()=>Nav("/tenant/students/create"))">
            Add Student
        </AppButton>
    </MudItem>

    <MudItem xs="12" md="3">
        <AppButton FullWidth="true" OnClick="@(()=>Nav("/tenant/fees/dashboard"))">
            Collect Fee
        </AppButton>
    </MudItem>

    <MudItem xs="12" md="3">
        <AppButton FullWidth="true" OnClick="@(()=>Nav("/tenant/students"))">
            Students
        </AppButton>
    </MudItem>

    <MudItem xs="12" md="3">
        <AppButton FullWidth="true" OnClick="@(()=>Nav("/tenant/reports"))">
            Reports
        </AppButton>
    </MudItem>

</MudGrid>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private void Nav(string url) => Navigation.NavigateTo(url);
}