



@using MudBlazor
@using Shala.Domain.Enums
@using Shala.Shared.Requests.Registration
@using Shala.Shared.Responses.Registration
@using Shala.Shared.Responses.Students
@using Shala.Web.Repositories.Interfaces
@using Shala.Web.Repositories.Registration
@using Shala.Web.Repositories.Registration.RegistrationConfig
@using Shala.Web.Services.State

@inject IRegistrationWebRepository Repo
@inject IStudentLookupRepository StudentLookupRepository
@inject IRegistrationFeeConfigurationWebRepository FeeConfigRepo
@inject IRegistrationProspectusConfigurationWebRepository ProspectusConfigRepo
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject ApiSession Session

<MudDialog>
    <TitleContent>
        @(Model is null ? "New Registration" : "Edit Registration")
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudDatePicker Label="Registration Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Date="_registrationDate"
                               DateChanged="OnRegistrationDateChanged"
                               Editable="true" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="int?"
                           Label="Interested Class"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           @bind-Value="_selectedClassId"
                           Required="true">
                    @foreach (var item in _classes)
                    {
                        <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="First Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.FirstName"
                              Required="true" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Middle Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.MiddleName" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Last Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.LastName"
                              Required="true" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudDatePicker Label="Date of Birth"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Date="_dob"
                               DateChanged="OnDobChanged"
                               Editable="true" />
            </MudItem>

            <MudSelect T="Gender?"
                       Label="Gender"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       @bind-Value="_createModel.Gender"
                       Required="true"
                       RequiredError="Gender is required.">
                <MudSelectItem T="Gender?" Value="@((Gender?)Gender.Male)">Male</MudSelectItem>
                <MudSelectItem T="Gender?" Value="@((Gender?)Gender.Female)">Female</MudSelectItem>
                <MudSelectItem T="Gender?" Value="@((Gender?)Gender.Other)">Other</MudSelectItem>
            </MudSelect>

            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Guardian Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.GuardianName"
                              Required="true" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Phone"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.Phone"
                              Required="true" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string"
                              Label="Address"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_createModel.Address" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string"
                              Label="Note"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3"
                              @bind-Value="_createModel.Note" />
            </MudItem>

            @if (Model is not null)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true">
                        <div><strong>Registration No:</strong> @Model.RegistrationNo</div>
                        <div><strong>Status:</strong> @Model.Status</div>
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">
            Cancel
        </MudButton>

        @if (Model is null)
        {
            <MudButton OnClick="CreateOrCollectFee"
                       Color="Color.Primary"
                       Variant="Variant.Filled">
                Next
            </MudButton>
        }
        else
        {
            <MudButton OnClick="UpdateOnly"
                       Color="Color.Primary"
                       Variant="Variant.Filled">
                Save
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public RegistrationDto? Model { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private CreateRegistrationRequest _createModel = new();
    private DateTime? _registrationDate = DateTime.Today;
    private DateTime? _dob;
    private int? _selectedClassId;
    private List<LookupItemResponse> _classes = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadClassesAsync();

        if (Model is null)
        {
            _createModel = new CreateRegistrationRequest
            {
                RegistrationDate = DateTime.Today
            };

            _registrationDate = _createModel.RegistrationDate;
            _dob = _createModel.DateOfBirth;
        }
        else
        {
            _createModel = new CreateRegistrationRequest
            {
                RegistrationDate = Model.RegistrationDate,
                FirstName = Model.FirstName,
                MiddleName = Model.MiddleName,
                LastName = Model.LastName,
                GuardianName = Model.GuardianName,
                Phone = Model.Phone,
                Address = Model.Address,
                Note = Model.Note,
                InterestedClassId = Model.InterestedClassId,
                DateOfBirth = Model.DateOfBirth,
                Gender = ParseGender(Model.Gender)
            };

            _registrationDate = Model.RegistrationDate;
            _dob = Model.DateOfBirth;
            _selectedClassId = Model.InterestedClassId;
        }
    }

    private async Task LoadClassesAsync()
    {
        try
        {
            if (!Session.TenantId.HasValue)
            {
                Snackbar.Add("Tenant not found in session.", Severity.Error);
                _classes = new List<LookupItemResponse>();
                return;
            }

            var classResponse = await StudentLookupRepository.GetClassesAsync(Session.TenantId.Value);

            _classes = classResponse?.Success == true && classResponse.Data is not null
                ? classResponse.Data
                : new List<LookupItemResponse>();
        }
        catch (Exception ex)
        {
            _classes = new List<LookupItemResponse>();
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void OnRegistrationDateChanged(DateTime? value)
    {
        _registrationDate = value ?? DateTime.Today;
        _createModel.RegistrationDate = _registrationDate.Value;
    }

    private void OnDobChanged(DateTime? value)
    {
        _dob = value;
        _createModel.DateOfBirth = value;
    }

    private async Task CreateOrCollectFee()
    {
        if (!ValidateRegistration())
            return;

        _createModel.InterestedClassId = _selectedClassId!.Value;
        _createModel.RegistrationDate = _registrationDate ?? DateTime.Today;
        _createModel.DateOfBirth = _dob;

        try
        {
            var feeConfig = await FeeConfigRepo.GetAsync();
            var prospectusConfig = await ProspectusConfigRepo.GetAsync();

            if (feeConfig is null || !feeConfig.IsActive)
            {
                var id = await Repo.CreateAsync(_createModel);
                Snackbar.Add($"Registration created successfully. Id: {id}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(id));
                return;
            }

            var parameters = new DialogParameters
            {
                ["DefaultAmount"] = feeConfig.RegistrationFeeAmount,
                ["IsMandatory"] = feeConfig.IsRegistrationFeeMandatory,
                ["IncludeProspectus"] = prospectusConfig?.IncludeProspectus ?? false,
                ["IsProspectusMandatory"] = prospectusConfig?.IsProspectusMandatory ?? false,
                ["ProspectusAmount"] = prospectusConfig?.ProspectusAmount ?? 0m,
                ["ProspectusDisplayName"] = prospectusConfig?.ProspectusDisplayName ?? "Prospectus"
            };

            var dialog = await Dialog.ShowAsync<RegistrationFeeDialog>("Collect Registration Fee", parameters);
            var result = await dialog.Result;

            if (result.Canceled)
            {
                if (feeConfig.IsRegistrationFeeMandatory)
                    return;

                var regId = await Repo.CreateAsync(_createModel);
                Snackbar.Add($"Registration created successfully. Id: {regId}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(regId));
                return;
            }

            if (result.Data is not CollectRegistrationFeeRequest feeRequest)
                return;

            var request = new SaveRegistrationWithFeeRequest
            {
                Registration = _createModel,
                Fee = feeRequest
            };

            var response = await Repo.SaveWithFeeAsync(request);

            Snackbar.Add($"Saved successfully. Receipt: {response.ReceiptNo}", Severity.Success);

            // Important: parent page will open receipt dialog
            MudDialog.Close(DialogResult.Ok(response));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task UpdateOnly()
    {
        if (!ValidateRegistration())
            return;

        try
        {
            var updateModel = new UpdateRegistrationRequest
            {
                RegistrationDate = _registrationDate ?? DateTime.Today,
                FirstName = _createModel.FirstName,
                MiddleName = _createModel.MiddleName,
                LastName = _createModel.LastName,
                GuardianName = _createModel.GuardianName,
                Phone = _createModel.Phone,
                Address = _createModel.Address,
                Note = _createModel.Note,
                InterestedClassId = _selectedClassId!.Value,
                DateOfBirth = _dob,
                Gender = _createModel.Gender
            };

            await Repo.UpdateAsync(Model!.Id, updateModel);
            Snackbar.Add("Updated successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private bool ValidateRegistration()
    {
        if (string.IsNullOrWhiteSpace(_createModel.FirstName) ||
            string.IsNullOrWhiteSpace(_createModel.LastName) ||
            string.IsNullOrWhiteSpace(_createModel.GuardianName) ||
            string.IsNullOrWhiteSpace(_createModel.Phone))
        {
            Snackbar.Add("Please fill all required fields.", Severity.Warning);
            return false;
        }

        if (!_selectedClassId.HasValue)
        {
            Snackbar.Add("Please select interested class.", Severity.Warning);
            return false;
        }

        return true;
    }

    private static Gender? ParseGender(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        return Enum.TryParse<Gender>(value, true, out var result) ? result : null;
    }

    private void Cancel() => MudDialog.Cancel();
}