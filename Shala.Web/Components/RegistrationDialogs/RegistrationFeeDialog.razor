@using MudBlazor
@using Shala.Domain.Enum
@using Shala.Shared.Requests.Registration

<MudDialog>
    <TitleContent>
        Collect Registration Fee
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true">
                    Enter fee collection details for this registration.
                </MudAlert>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudNumericField T="decimal?"
                                 Label="Registration Fee Amount"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0"
                                 Immediate="true"
                                 @bind-Value="_model.Amount"
                                 Required="@IsMandatory" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="PaymentMode"
                           Label="Payment Mode"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           @bind-Value="_model.PaymentMode">
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.Cash">Cash</MudSelectItem>
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.Upi">UPI</MudSelectItem>
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.BankTransfer">Bank Transfer</MudSelectItem>
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.Cheque">Cheque</MudSelectItem>
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.Card">Card</MudSelectItem>
                    <MudSelectItem T="PaymentMode" Value="PaymentMode.Other">Other</MudSelectItem>
                </MudSelect>
            </MudItem>

            @if (IncludeProspectus)
            {
                <MudItem xs="12">
                    <MudCheckBox T="bool"
                                 Label="@($"Include {ProspectusDisplayName}")"
                                 @bind-Value="_model.IncludeProspectus" />
                </MudItem>

                @if (_model.IncludeProspectus)
                {
                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal?"
                                         Label="@($"{ProspectusDisplayName} Amount")"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Immediate="true"
                                         @bind-Value="_model.ProspectusAmount"
                                         Required="@IsProspectusMandatory" />
                    </MudItem>
                }
            }

            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Transaction Reference"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="UPI/Bank/Cheque reference"
                              @bind-Value="_model.TransactionReference" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField T="string"
                              Label="Remarks"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3"
                              @bind-Value="_model.Remarks" />
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle2" Class="fw-semibold">Summary</MudText>
                        <MudText Typo="Typo.body2">
                            Registration Fee: ₹ @((_model.Amount ?? 0m).ToString("0.##"))
                        </MudText>

                        @if (_model.IncludeProspectus)
                        {
                            <MudText Typo="Typo.body2">
                                @ProspectusDisplayName: ₹ @((_model.ProspectusAmount ?? 0m).ToString("0.##"))
                            </MudText>
                        }

                        <MudDivider />

                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                            Total: ₹ @GetTotal().ToString("0.##")
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">
            Cancel
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public decimal? DefaultAmount { get; set; }
    [Parameter] public bool IsMandatory { get; set; }
    [Parameter] public bool IncludeProspectus { get; set; }
    [Parameter] public bool IsProspectusMandatory { get; set; }
    [Parameter] public decimal? ProspectusAmount { get; set; }
    [Parameter] public string ProspectusDisplayName { get; set; } = "Prospectus";

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private CollectRegistrationFeeRequest _model = new();

    protected override void OnInitialized()
    {
        _model.Amount = DefaultAmount;
        _model.PaymentMode = PaymentMode.Cash;
        _model.IncludeProspectus = IncludeProspectus && (IsProspectusMandatory || (ProspectusAmount ?? 0m) > 0m);
        _model.ProspectusAmount = ProspectusAmount;
    }

    private decimal GetTotal()
    {
        var registrationAmount = _model.Amount ?? 0m;
        var prospectusAmount = _model.IncludeProspectus ? (_model.ProspectusAmount ?? 0m) : 0m;
        return registrationAmount + prospectusAmount;
    }

    private void Submit()
    {
        if (IsMandatory && (!_model.Amount.HasValue || _model.Amount.Value <= 0))
        {
            Snackbar.Add("Registration fee amount is required.", Severity.Warning);
            return;
        }

        if (_model.Amount.HasValue && _model.Amount.Value < 0)
        {
            Snackbar.Add("Registration fee amount cannot be negative.", Severity.Warning);
            return;
        }

        if (_model.IncludeProspectus)
        {
            if (IsProspectusMandatory && (!_model.ProspectusAmount.HasValue || _model.ProspectusAmount.Value <= 0))
            {
                Snackbar.Add($"{ProspectusDisplayName} amount is required.", Severity.Warning);
                return;
            }

            if (_model.ProspectusAmount.HasValue && _model.ProspectusAmount.Value < 0)
            {
                Snackbar.Add($"{ProspectusDisplayName} amount cannot be negative.", Severity.Warning);
                return;
            }
        }
        else
        {
            _model.ProspectusAmount = null;
        }

        if (_model.PaymentMode != PaymentMode.Cash &&
            string.IsNullOrWhiteSpace(_model.TransactionReference))
        {
            Snackbar.Add("Transaction reference is required for non-cash payment.", Severity.Warning);
            return;
        }

        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}