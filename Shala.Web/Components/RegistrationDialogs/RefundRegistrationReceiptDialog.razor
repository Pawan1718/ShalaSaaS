@using MudBlazor
@using Shala.Shared.Requests.Registration

<MudDialog>
    <TitleContent>Refund Receipt</TitleContent>

    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Enter refund amount and reason.
        </MudText>

        <MudNumericField T="decimal"
                         Label="Refund Amount"
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Min="0"
                         Max="MaxAmount"
                         @bind-Value="_amount" />

        <MudTextField T="string"
                      Label="Refund Reason"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="3"
                      @bind-Value="_reason"
                      Required="true" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
        <MudButton Color="Color.Warning"
                   Variant="Variant.Filled"
                   OnClick="Submit">
            Refund
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public decimal MaxAmount { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private decimal _amount;
    private string _reason = string.Empty;

    protected override void OnInitialized()
    {
        _amount = MaxAmount;
    }

    private void Submit()
    {
        if (_amount <= 0 || _amount > MaxAmount || string.IsNullOrWhiteSpace(_reason))
            return;

        MudDialog.Close(DialogResult.Ok(new RefundRegistrationReceiptRequest
        {
            Amount = _amount,
            Reason = _reason.Trim()
        }));
    }

    private void Cancel() => MudDialog.Cancel();
}