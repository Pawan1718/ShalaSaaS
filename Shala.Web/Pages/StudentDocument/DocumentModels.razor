@page "/tenant/settings/document-models"

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.StudentDocument
@using Shala.Shared.Responses.StudentDocument
@using Shala.Web.Components.StudentDocuments
@using Shala.Web.Repositories.StudentDocuments
@layout Components.Layouts.TenantMainLayout
@inject IDocumentModelWebRepository Repo
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Document Models</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack Spacing="3">

        <MudPaper Class="pa-5 rounded-xl">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold">Document Models</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                        Configure allowed document types, AI validation, admission block rules, and active/inactive state.
                    </MudText>
                </div>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadAsync"
                               Disabled="_loading">
                        Reload
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateDialogAsync"
                               Disabled="_loading">
                        Add Document Model
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">
                @_error
            </MudAlert>
        }

        <MudPaper Class="pa-4 rounded-xl">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <MudTextField T="string"
                              Placeholder="Search by name or code..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Style="max-width: 320px;"
                              @bind-Value="_searchText"
                              Immediate="true" />

                <MudSwitch T="bool"
                           @bind-Value="_showOnlyActive"
                           Color="Color.Primary"
                           Label="Show only active" />
            </MudStack>
        </MudPaper>

        <MudPaper Class="rounded-xl overflow-hidden">
            @if (_loading)
            {
                <MudStack Class="pa-6" AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">Loading document models...</MudText>
                </MudStack>
            }
            else if (!FilteredItems.Any())
            {
                <MudStack Class="pa-6" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6">No document models found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Create your first document model to begin configuration.</MudText>
                </MudStack>
            }
            else
            {
                <MudTable Items="FilteredItems" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Code</MudTh>
                        <MudTh>Rules</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Order</MudTh>
                        <MudTh style="width:220px;">Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                                @if (!string.IsNullOrWhiteSpace(context.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                                }
                            </MudStack>
                        </MudTd>

                        <MudTd>
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@context.Code</MudChip>
                        </MudTd>

                        <MudTd>
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @if (context.IsRequired)
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Required</MudChip>
                                }
                                @if (context.IsAiValidationEnabled)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">AI Check</MudChip>
                                }
                                @if (context.BlockAdmissionOnMismatch)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Block Admission</MudChip>
                                }
                            </MudStack>
                        </MudTd>

                        <MudTd>
                            <MudChip T="string"
                                     Color="@(context.IsActive ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled"
                                     Size="Size.Small">
                                @(context.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudTd>

                        <MudTd>@context.DisplayOrder</MudTd>

                        <MudTd>
                            <MudStack Row="true" Spacing="1">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => OpenEditDialogAsync(context))" />

                                <MudIconButton Icon="@(context.IsActive ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                               Color="@(context.IsActive ? Color.Success : Color.Default)"
                                               Size="Size.Small"
                                               OnClick="@(() => ToggleStatusAsync(context))" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private List<DocumentModelResponse> _items = new();
    private bool _loading;
    private string? _error;
    private string _searchText = string.Empty;
    private bool _showOnlyActive;

    private IEnumerable<DocumentModelResponse> FilteredItems =>
        _items
            .Where(x => !_showOnlyActive || x.IsActive)
            .Where(x =>
                string.IsNullOrWhiteSpace(_searchText) ||
                (x.Name?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.Code?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderBy(x => x.DisplayOrder)
            .ThenBy(x => x.Name);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_loading)
            return;

        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _items = await Repo.GetAllAsync();
        }
        catch (Exception ex)
        {
            _items = new();
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenCreateDialogAsync()
    {
        if (_loading)
            return;

        var parameters = new DialogParameters
        {
            [nameof(DocumentModelEditorDialog.Model)] = new CreateDocumentModelRequest
            {
                IsAiValidationEnabled = true,
                IsRequired = false,
                BlockAdmissionOnMismatch = false,
                AllowedFileTypes = "pdf,jpg,jpeg,png",
                MaxFileSizeInKb = 2048,
                DisplayOrder = (_items.Any() ? _items.Max(x => x.DisplayOrder) : 0) + 1
            },
            [nameof(DocumentModelEditorDialog.EditId)] = 0,
            [nameof(DocumentModelEditorDialog.IsEdit)] = false
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<DocumentModelEditorDialog>(
            "Add Document Model",
            parameters,
            options);

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task OpenEditDialogAsync(DocumentModelResponse item)
    {
        if (_loading)
            return;

        var parameters = new DialogParameters
        {
            [nameof(DocumentModelEditorDialog.Model)] = new CreateDocumentModelRequest
            {
                Name = item.Name,
                Code = item.Code,
                Description = item.Description,
                IsRequired = item.IsRequired,
                IsAiValidationEnabled = item.IsAiValidationEnabled,
                BlockAdmissionOnMismatch = item.BlockAdmissionOnMismatch,
                AllowedFileTypes = item.AllowedFileTypes,
                MaxFileSizeInKb = item.MaxFileSizeInKb,
                RequiredFieldsJson = item.RequiredFieldsJson,
                DisplayOrder = item.DisplayOrder
            },
            [nameof(DocumentModelEditorDialog.EditId)] = item.Id,
            [nameof(DocumentModelEditorDialog.IsEdit)] = true
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<DocumentModelEditorDialog>(
            "Edit Document Model",
            parameters,
            options);

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task ToggleStatusAsync(DocumentModelResponse item)
    {
        try
        {
            await Repo.ToggleStatusAsync(new ToggleDocumentModelStatusRequest
            {
                Id = item.Id,
                IsActive = !item.IsActive
            });

            Snackbar.Add(
                item.IsActive ? "Document model deactivated successfully." : "Document model activated successfully.",
                Severity.Success);

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}