@page "/tenant/students/{StudentId:int}/admissions/{AdmissionId:int}/fees"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.Fees
@using Shala.Shared.Responses.Fees
@using Shala.Web.Components.Fees
@using Shala.Web.Models.Fees
@using Shala.Web.Repositories.Fees
@using Shala.Web.Repositories.Settings
@using Shala.Shared.Responses.Settings



@inject IBranchDocumentProfileWebRepository ProfileRepo
@inject IFeeWebRepository FeeWebRepository
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Admission Fees</PageTitle>

@if (_loading)
{
    <MudPaper Class="pa-10 d-flex justify-center align-center" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading fee workspace...</MudText>
        </MudStack>
    </MudPaper>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
        @_error
    </MudAlert>
}
else
{
    <MudStack Spacing="3">

        <!-- Hero -->
        <MudPaper Class="pa-5 pa-md-6" Elevation="2" Style="background: linear-gradient(135deg, rgba(25,118,210,0.10), rgba(156,39,176,0.10), rgba(46,125,50,0.10)); border-radius: 20px;">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" lg="7">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                                <MudIcon Icon="@Icons.Material.Filled.Payments" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h4">Admission Fees</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Assign plans, generate installments, collect payments, and manage receipts from one place.
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                Student #@StudentId
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small">
                                Admission #@AdmissionId
                            </MudChip>
                            <MudChip T="string"
                                     Variant="Variant.Filled"
                                     Color="@GetWorkflowColor()"
                                     Size="Size.Small">
                                @GetWorkflowText()
                            </MudChip>
                        </MudStack>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <MudStack Spacing="2" AlignItems="AlignItems.End">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Quick Actions</MudText>

                        <MudStack Row="true"
                                  Spacing="1"
                                  Wrap="Wrap.Wrap"
                                  Justify="Justify.FlexEnd">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       OnClick="GoBack">
                                Back
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                                       Disabled="@(_dashboard.Assignment is not null)"
                                       OnClick="OpenAssignDialogAsync">
                                @(_dashboard.Assignment is null ? "Assign Structure" : "Assigned")
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                       Disabled="@(_dashboard.Assignment is null || _dashboard.Charges.Any())"
                                       OnClick="GenerateChargesAsync">
                                Generate Charges
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Payments"
                                       Disabled="@(!CanCollectFee)"
                                       OnClick="OpenCollectFeeDialogAsync">
                                Collect Fee
                            </MudButton>
                        </MudStack>

                        <MudAlert Severity="@GetGuidanceSeverity()" Variant="Variant.Outlined" Dense="true" Class="mt-2" Style="max-width: 460px;">
                            @GetGuidanceMessage()
                        </MudAlert>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Summary -->
        <FeeSummaryCards Summary="_dashboard.Summary" />

        <!-- Insight Cards -->
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="pa-4 h-100" Elevation="2" Style="border-left: 6px solid var(--mud-palette-primary); border-radius: 18px;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1">Fee Plan Summary</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Current structure linked to this admission</MudText>
                            </div>
                        </MudStack>

                        @if (_dashboard.Assignment is null)
                        {
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudText Typo="Typo.subtitle2">No plan assigned yet</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                    Assign a fee structure first to unlock the next steps.
                                </MudText>
                            </MudPaper>
                        }
                        else
                        {
                            <MudGrid Spacing="2">
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Fee Plan</MudText>
                                    <MudText Typo="Typo.h6">@DisplayText(_dashboard.Assignment.FeeStructureName)</MudText>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned On</MudText>
                                    <MudText Typo="Typo.body1">@FormatDate(_dashboard.Assignment.CreatedAt)</MudText>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                                    <MudChip T="string"
                                             Color="@(_dashboard.Assignment.IsActive ? Color.Success : Color.Default)"
                                             Variant="Variant.Filled"
                                             Size="Size.Small">
                                        @(_dashboard.Assignment.IsActive ? "Active" : "Inactive")
                                    </MudChip>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Discount</MudText>
                                    <MudText Typo="Typo.body1">@_dashboard.Assignment.DiscountAmount.ToString("N2")</MudText>
                                </MudItem>

                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Additional</MudText>
                                    <MudText Typo="Typo.body1">@_dashboard.Assignment.AdditionalChargeAmount.ToString("N2")</MudText>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Collection Mode</MudText>
                                    <MudText Typo="Typo.body1">Installment Based</MudText>
                                </MudItem>
                            </MudGrid>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudPaper Class="pa-4 h-100" Elevation="2" Style="border-left: 6px solid var(--mud-palette-success); border-radius: 18px;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Success" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1">Collection Overview</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Quick financial view of this admission</MudText>
                            </div>
                        </MudStack>

                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Paid</MudText>
                                    <MudText Typo="Typo.h6">@_dashboard.Summary.TotalPaid.ToString("N2")</MudText>
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="6">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                                    <MudText Typo="Typo.h6">@_dashboard.Summary.TotalBalance.ToString("N2")</MudText>
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="6">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Installments</MudText>
                                    <MudText Typo="Typo.h6">@_dashboard.Summary.TotalInstallments</MudText>
                                </MudPaper>
                            </MudItem>

                            <MudItem xs="6">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Receipts</MudText>
                                    <MudText Typo="Typo.h6">@_dashboard.Receipts.Count</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        <MudDivider />

                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Collection Progress</MudText>
                            <MudProgressLinear Value="@GetCollectionProgress()" Color="Color.Success" Rounded="true" Class="mt-2 mb-1" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @GetCollectionProgress().ToString("N0")% collected
                            </MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="pa-4 h-100" Elevation="2" Style="border-left: 6px solid var(--mud-palette-warning); border-radius: 18px;">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudAvatar Color="@GetWorkflowColor()" Variant="Variant.Filled">
                                <MudIcon Icon="@GetNextActionIcon()" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1">Next Best Action</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">What the operator should do now</MudText>
                            </div>
                        </MudStack>

                        <MudPaper Class="pa-3" Outlined="true">
                            <MudText Typo="Typo.subtitle2">@GetNextActionTitle()</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                @GetNextActionDescription()
                            </MudText>
                        </MudPaper>

                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @if (_dashboard.Assignment is null)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                                           OnClick="OpenAssignDialogAsync">
                                    Assign Structure
                                </MudButton>
                            }
                            else if (!_dashboard.Charges.Any())
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                           OnClick="GenerateChargesAsync">
                                    Generate Charges
                                </MudButton>
                            }
                            else if (CanCollectFee)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Payments"
                                           OnClick="OpenCollectFeeDialogAsync">
                                    Collect Fee
                                </MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">
                                    All current dues are settled
                                </MudChip>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Work Area -->
        <MudTabs Rounded="true" PanelClass="pa-0" Elevation="1" Color="Color.Primary">
            <MudTabPanel Text="Charges & Installments" Icon="@Icons.Material.Filled.ReceiptLong">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 16px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6">Charges & Installments</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Review generated installments, amounts, and current payment status.
                            </MudText>
                        </div>

                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info">
                            @_dashboard.Charges.Count installment(s)
                        </MudChip>
                    </MudStack>

                    @if (!_dashboard.Charges.Any())
                    {
                        <MudPaper Class="pa-5" Outlined="true">
                            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Info">
                                    <MudIcon Icon="@Icons.Material.Filled.TableRows" />
                                </MudAvatar>
                                <MudText Typo="Typo.subtitle1">No installments created yet</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                    Once charges are generated from the assigned fee plan, they will appear here.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <StudentChargesTable Charges="_dashboard.Charges" />
                    }
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Receipts" Icon="@Icons.Material.Filled.Receipt">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 16px;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6">Receipts</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                View collected payments and issued receipt entries for this admission.
                            </MudText>
                        </div>

                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success">
                            @_dashboard.Receipts.Count receipt(s)
                        </MudChip>
                    </MudStack>

                    @if (!_dashboard.Receipts.Any())
                    {
                        <MudPaper Class="pa-5" Outlined="true">
                            <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Success">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" />
                                </MudAvatar>
                                <MudText Typo="Typo.subtitle1">No receipts recorded</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                                    Receipt entries will appear here after fee collection is recorded.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                    else
                    {
                        <FeeReceiptsTable Receipts="_dashboard.Receipts"
                                          OnViewReceipt="OpenReceiptFromListAsync" />
                    }
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}

@code {
    [Parameter] public int StudentId { get; set; }
    [Parameter] public int AdmissionId { get; set; }

    private bool _loading = true;
    private string? _error;
    private AdmissionFeeDashboardVm _dashboard = new();

    private bool CanCollectFee =>
        _dashboard.Charges.Any(x => !x.IsCancelled && x.BalanceAmount > 0);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            var structuresTask = FeeWebRepository.GetFeeStructuresAsync();
            var chargesTask = FeeWebRepository.GetStudentChargesAsync(StudentId);
            var receiptsTask = FeeWebRepository.GetStudentReceiptsAsync(StudentId);
            var assignmentTask = FeeWebRepository.GetAssignmentAsync(AdmissionId);

            await Task.WhenAll(structuresTask, chargesTask, receiptsTask, assignmentTask);

            var structures = await structuresTask;
            var charges = await chargesTask;
            var receipts = await receiptsTask;
            var assignment = await assignmentTask;

            _dashboard.AvailableStructures = structures;
            _dashboard.Assignment = assignment;

            _dashboard.Charges = charges
                .Where(x => x.StudentAdmissionId == AdmissionId)
                .OrderBy(x => x.DueDate)
                .ToList();

            _dashboard.Receipts = receipts
                .Where(x => x.StudentAdmissionId == AdmissionId)
                .OrderByDescending(x => x.ReceiptDate)
                .ToList();

            _dashboard.Summary = BuildSummary(_dashboard.Charges);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/tenant/students/{StudentId}");
    }

    private async Task GenerateChargesAsync()
    {
        if (_dashboard.Assignment is null)
        {
            Snackbar.Add("No assignment found.", Severity.Warning);
            return;
        }

        if (_dashboard.Charges.Any())
        {
            Snackbar.Add("Charges already generated for this admission.", Severity.Warning);
            return;
        }

        try
        {
            await FeeWebRepository.GenerateChargesAsync(_dashboard.Assignment.Id);
            Snackbar.Add("Charges generated successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenAssignDialogAsync()
    {
        if (_dashboard.Assignment is not null)
        {
            Snackbar.Add("Fee structure already assigned for this admission.", Severity.Warning);
            return;
        }

        var activeStructures = _dashboard.AvailableStructures
            .Where(x => x.IsActive)
            .OrderBy(x => x.Name)
            .ToList();

        if (!activeStructures.Any())
        {
            Snackbar.Add("No active fee structures available.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters
        {
            [nameof(AssignFeeStructureDialog.FeeStructures)] = activeStructures
        };

        var dialog = await DialogService.ShowAsync<AssignFeeStructureDialog>(
            "Assign Fee Structure",
            parameters);

        var result = await dialog.Result;
        if (result.Canceled || result.Data is not AssignFeeStructureVm model)
            return;

        try
        {
            var request = new CreateStudentFeeAssignmentRequest
            {
                StudentId = StudentId,
                StudentAdmissionId = AdmissionId,
                FeeStructureId = model.FeeStructureId,
                DiscountAmount = model.DiscountAmount,
                AdditionalChargeAmount = model.AdditionalChargeAmount,
                IsActive = true
            };

            var assignment = await FeeWebRepository.AssignFeeStructureAsync(request);
            _dashboard.Assignment = assignment;

            Snackbar.Add("Fee structure assigned successfully.", Severity.Success);

            if (model.AutoGenerateCharges && assignment is not null)
            {
                await FeeWebRepository.GenerateChargesAsync(assignment.Id);
                Snackbar.Add("Charges generated successfully.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Structure assigned. Generate charges to enable fee collection.", Severity.Info);
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenCollectFeeDialogAsync()
    {
        if (!CanCollectFee)
        {
            Snackbar.Add("No pending balance available for collection.", Severity.Warning);
            return;
        }

        var dialog = await DialogService.ShowAsync<CollectFeeDialog>(
            "Collect Fee",
            new DialogParameters
            {
                [nameof(CollectFeeDialog.StudentId)] = StudentId,
                [nameof(CollectFeeDialog.StudentAdmissionId)] = AdmissionId,
                [nameof(CollectFeeDialog.Charges)] = _dashboard.Charges
            });

        var result = await dialog.Result;
        if (result.Canceled || result.Data is not CreateFeeReceiptRequest request)
            return;

        try
        {
            var response = await FeeWebRepository.CollectFeeAsync(request);
            Snackbar.Add("Fee collected successfully.", Severity.Success);

            await LoadAsync();
            await OpenReceiptActionDialogAsync(response.Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private Color GetWorkflowColor()
    {
        if (_dashboard.Assignment is null)
            return Color.Warning;

        if (!_dashboard.Charges.Any())
            return Color.Info;

        if (CanCollectFee)
            return Color.Success;

        return Color.Primary;
    }

    private string GetWorkflowText()
    {
        if (_dashboard.Assignment is null)
            return "Pending Assignment";

        if (!_dashboard.Charges.Any())
            return "Ready to Generate";

        if (CanCollectFee)
            return "Ready to Collect";

        return "Completed";
    }

    private Severity GetGuidanceSeverity()
    {
        if (_dashboard.Assignment is null)
            return Severity.Warning;

        if (!_dashboard.Charges.Any())
            return Severity.Info;

        if (CanCollectFee)
            return Severity.Success;

        return Severity.Normal;
    }

    private string GetGuidanceMessage()
    {
        if (_dashboard.Assignment is null)
            return "Assign a fee structure first. This links a fee plan to the current admission.";

        if (!_dashboard.Charges.Any())
            return "The fee plan is assigned. Generate charges now to create installments for collection.";

        if (CanCollectFee)
            return "Charges are ready and some balance is still pending. You can collect fee now.";

        return "All current charges are settled or no pending collection remains.";
    }

    private string GetNextActionTitle()
    {
        if (_dashboard.Assignment is null)
            return "Assign the fee plan";

        if (!_dashboard.Charges.Any())
            return "Generate installments";

        if (CanCollectFee)
            return "Collect pending fee";

        return "Review records";
    }

    private string GetNextActionDescription()
    {
        if (_dashboard.Assignment is null)
            return "Choose a structure so this admission can move into billing.";

        if (!_dashboard.Charges.Any())
            return "Create installment rows from the assigned fee plan.";

        if (CanCollectFee)
            return "Record a payment against the pending balance and issue a receipt.";

        return "All current items are settled. You can review charges and receipts anytime.";
    }

    private string GetNextActionIcon()
    {
        if (_dashboard.Assignment is null)
            return Icons.Material.Filled.AccountBalanceWallet;

        if (!_dashboard.Charges.Any())
            return Icons.Material.Filled.AutoFixHigh;

        if (CanCollectFee)
            return Icons.Material.Filled.Payments;

        return Icons.Material.Filled.DoneAll;
    }

    private double GetCollectionProgress()
    {
        if (_dashboard.Summary.TotalAmount <= 0)
            return 0;

        var value = (_dashboard.Summary.TotalPaid / _dashboard.Summary.TotalAmount) * 100m;
        return (double)Math.Min(100m, Math.Max(0m, value));
    }

    private static string DisplayText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string FormatDate(DateTime value)
    {
        return value == default ? "-" : value.ToString("dd MMM yyyy");
    }
    private async Task OpenReceiptActionDialogAsync(int receiptId)
    {
        try
        {
            var receipt = _dashboard.Receipts.FirstOrDefault(x => x.Id == receiptId);

            if (receipt is null)
            {
                await LoadAsync();
                receipt = _dashboard.Receipts.FirstOrDefault(x => x.Id == receiptId);
            }

            if (receipt is null)
            {
                Snackbar.Add("Receipt preview could not be loaded.", Severity.Warning);
                return;
            }

            var profile = await ProfileRepo.GetAsync();

            var allocations = receipt.Allocations?
                .Where(x => x.AllocatedAmount != 0)
                .ToList() ?? new List<FeeReceiptAllocationResponse>();

            var lines = allocations
                .Select(allocation =>
                {
                    var charge = _dashboard.Charges.FirstOrDefault(c => c.Id == allocation.StudentChargeId);

                    return new FeeReceiptPrintLineVm
                    {
                        Label = charge?.ChargeLabel ?? $"Charge #{allocation.StudentChargeId}",
                        FeeHeadName = null,
                        DueDate = charge?.DueDate,
                        Amount = allocation.AllocatedAmount
                    };
                })
                .ToList();

            var computedTotal = lines.Sum(x => x.Amount);

            var printModel = new FeeReceiptPrintVm
            {
                ReceiptId = receipt.Id,
                ReceiptNo = receipt.ReceiptNo,
                ReceiptDate = receipt.ReceiptDate,
                ReceiptTitle = "Fee Receipt",
                ReceiptFooterNote = "This is a computer-generated receipt.",

                // Keep safe placeholders for now until real student/admission detail DTO is added
                StudentName = $"Student #{StudentId}",
                AdmissionNo = $"Admission #{AdmissionId}",
                ClassName = "-",
                SectionName = null,
                RollNo = null,
                GuardianName = null,
                Phone = null,

                PaymentMode = GetPaymentModeText(receipt.PaymentMode),
                TransactionReference = receipt.TransactionReference,
                Remarks = receipt.Remarks,

                ShowStudentDetailsInReceipt = true,
                ShowFeeHeadInReceipt = true,
                ShowAmountInWords = true,
                AllowPrintReceipt = true,
                AllowDownloadReceipt = true,

                TotalAmount = receipt.TotalAmount > 0 ? receipt.TotalAmount : computedTotal,
                AmountInWords = $"{(receipt.TotalAmount > 0 ? receipt.TotalAmount : computedTotal):N2} only",

                Lines = lines
            };

            var parameters = new DialogParameters
            {
                [nameof(FeeReceiptActionDialog.Model)] = printModel,
                [nameof(FeeReceiptActionDialog.Profile)] = profile
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraLarge,
                FullWidth = true,
                CloseButton = true
            };

            await DialogService.ShowAsync<FeeReceiptActionDialog>(
                "Fee Receipt",
                parameters,
                options);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
    }


    private async Task OpenReceiptFromListAsync(FeeReceiptResponse receipt)
    {
        await OpenReceiptActionDialogAsync(receipt.Id);
    }

    private static string GetPaymentModeText(int paymentMode) => paymentMode switch
    {
        1 => "Cash",
        2 => "UPI",
        3 => "Bank Transfer",
        4 => "Cheque",
        5 => "Card",
        _ => "Other"
    };

    private static FeeSummaryVm BuildSummary(List<StudentChargeResponse> charges)
    {
        return new FeeSummaryVm
        {
            TotalAmount = charges.Sum(x => x.Amount),
            TotalDiscount = charges.Sum(x => x.DiscountAmount),
            TotalPaid = charges.Sum(x => x.PaidAmount),
            TotalBalance = charges.Sum(x => x.BalanceAmount),

            TotalInstallments = charges.Count(x => !x.IsCancelled),
            PaidInstallments = charges.Count(x => !x.IsCancelled && x.BalanceAmount <= 0),
            PartialInstallments = charges.Count(x => !x.IsCancelled && x.PaidAmount > 0 && x.BalanceAmount > 0),
            PendingInstallments = charges.Count(x => !x.IsCancelled && x.PaidAmount <= 0 && x.BalanceAmount > 0)
        };
    }
}