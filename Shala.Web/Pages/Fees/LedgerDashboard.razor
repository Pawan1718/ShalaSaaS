@page "/tenant/ledger"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.Fees
@using Shala.Shared.Responses.Fees
@using Shala.Web.Repositories.Fees

@inject IFeeWebRepository FeeRepo
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Ledger Dashboard</PageTitle>

@if (_loading)
{
    <MudPaper Class="pa-8 d-flex justify-center align-center" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading ledger dashboard...</MudText>
        </MudStack>
    </MudPaper>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
        @_error
    </MudAlert>
}
else
{
    <MudStack Spacing="3">

        <MudPaper Class="pa-5 pa-md-6" Elevation="2" Style="border-radius: 20px;">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" lg="7">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h4">Ledger Dashboard</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Central transaction history for finance and stock. Fees Ledger is active now. Supply Stock Ledger will be added in the next phase.
                                </MudText>
                            </div>
                        </MudStack>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <MudStack Spacing="2" AlignItems="AlignItems.End">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                                   OnClick="GoToFeesDashboard">
                            Fees Dashboard
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudTabs Rounded="true" Elevation="1" PanelClass="pa-4" Color="Color.Primary">
            <MudTabPanel Text="Fees Ledger" Icon="@Icons.Material.Filled.ReceiptLong">

                <MudGrid Spacing="3" Class="mb-1">
                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Entries</MudText>
                            <MudText Typo="Typo.h5">@_data.Summary.TotalEntries</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Debit</MudText>
                            <MudText Typo="Typo.h5">@_data.Summary.TotalDebit.ToString("N2")</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Credit</MudText>
                            <MudText Typo="Typo.h5">@_data.Summary.TotalCredit.ToString("N2")</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" lg="3">
                        <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Closing Balance</MudText>
                            <MudText Typo="Typo.h5">@_data.Summary.ClosingBalance.ToString("N2")</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4 mb-3" Elevation="1" Style="border-radius:18px;">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudTextField T="string"
                                          Label="Search"
                                          Placeholder="Student, admission no, reference, remarks"
                                          @bind-Value="_request.SearchText"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudSelect T="string"
                                       Label="Entry Type"
                                       @bind-Value="_request.EntryType"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true">
                                <MudSelectItem T="string" Value="@("Charge")">Charge</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Discount")">Discount</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Fine")">Fine</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Receipt")">Receipt</MudSelectItem>
                                <MudSelectItem T="string" Value="@("ReceiptCancel")">ReceiptCancel</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Adjustment")">Adjustment</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="2">
                            <MudDatePicker Label="From"
                                           Date="_fromDate"
                                           DateChanged="OnFromDateChanged"
                                           Margin="Margin.Dense"
                                           Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12" md="2">
                            <MudDatePicker Label="To"
                                           Date="_toDate"
                                           DateChanged="OnToDateChanged"
                                           Margin="Margin.Dense"
                                           Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12" md="1">
                            <MudSelect T="int"
                                       Label="Rows"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Value="_request.PageSize"
                                       ValueChanged="OnPageSizeChangedAsync">
                                <MudSelectItem T="int" Value="10">10</MudSelectItem>
                                <MudSelectItem T="int" Value="25">25</MudSelectItem>
                                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                                <MudSelectItem T="int" Value="100">100</MudSelectItem>
                                <MudSelectItem T="int" Value="-1">All</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Spacing="1" Class="mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync">
                            Search
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetAsync">
                            Reset
                        </MudButton>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-0" Elevation="1" Style="border-radius:18px; overflow:hidden;">
                    <MudTable T="FeeLedgerRowResponse"
                              Items="_data.Entries.Items"
                              Dense="true"
                              Hover="true"
                              Striped="true"
                              Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Student</MudTh>
                            <MudTh>Admission</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh Align="right">Debit</MudTh>
                            <MudTh Align="right">Credit</MudTh>
                            <MudTh Align="right">Balance</MudTh>
                            <MudTh>Reference</MudTh>
                            <MudTh>Remarks</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd DataLabel="Date">@context.EntryDate.ToString("dd MMM yyyy")</MudTd>
                            <MudTd DataLabel="Student">@context.StudentName</MudTd>
                            <MudTd DataLabel="Admission">@context.AdmissionNo</MudTd>
                            <MudTd DataLabel="Type">
                                <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="@GetEntryTypeColor(context.EntryType)">
                                    @context.EntryType
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Debit" Align="right">@context.DebitAmount.ToString("N2")</MudTd>
                            <MudTd DataLabel="Credit" Align="right">@context.CreditAmount.ToString("N2")</MudTd>
                            <MudTd DataLabel="Balance" Align="right">@context.RunningBalance.ToString("N2")</MudTd>
                            <MudTd DataLabel="Reference">@DisplayText(context.ReferenceNo)</MudTd>
                            <MudTd DataLabel="Remarks">@DisplayText(context.Remarks)</MudTd>
                        </RowTemplate>

                        <NoRecordsContent>
                            <div class="pa-6">
                                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Info">
                                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6">No ledger entries found</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        Once fee ledger posting starts, entries will appear here.
                                    </MudText>
                                </MudStack>
                            </div>
                        </NoRecordsContent>
                    </MudTable>

                    <MudDivider />

                    <div class="pa-4">
                        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @GetPagingText()
                                </MudText>
                            </MudItem>

                            <MudItem xs="12" md="6" Class="d-flex justify-end">
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Variant="Variant.Outlined"
                                               Disabled="@(_data.Entries.PageSize == -1 || _data.Entries.PageNumber <= 1)"
                                               OnClick="PreviousPageAsync">
                                        Prev
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               Disabled="@(_data.Entries.PageSize == -1 || _data.Entries.PageNumber >= _totalPages)"
                                               OnClick="NextPageAsync">
                                        Next
                                    </MudButton>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Supply Stock Ledger" Icon="@Icons.Material.Filled.Inventory2" Disabled="true">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Supply stock ledger will be added here in the next phase.
                </MudAlert>
            </MudTabPanel>
        </MudTabs>
    </MudStack>
}

@code {
    private readonly FeeLedgerDashboardRequest _request = new()
    {
        PageNumber = 1,
        PageSize = 10,
        SortBy = "EntryDate",
        SortDescending = true
    };

    private FeeLedgerDashboardResponse _data = new();
    private bool _loading = true;
    private string? _error;
    private int _totalPages = 1;

    private DateTime? _fromDate;
    private DateTime? _toDate;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _data = await FeeRepo.GetFeeLedgerDashboardAsync(_request);

            _totalPages = _data.Entries.PageSize == -1
                ? 1
                : Math.Max(1, (int)Math.Ceiling((double)_data.Entries.TotalCount / _data.Entries.PageSize));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        _request.PageNumber = 1;
        await LoadAsync();
    }

    private async Task ResetAsync()
    {
        _request.SearchText = null;
        _request.EntryType = null;
        _request.StudentId = null;
        _request.AdmissionId = null;
        _request.FromDate = null;
        _request.ToDate = null;
        _request.PageNumber = 1;
        _request.PageSize = 10;
        _request.SortBy = "EntryDate";
        _request.SortDescending = true;

        _fromDate = null;
        _toDate = null;

        await LoadAsync();
    }

    private Task OnFromDateChanged(DateTime? value)
    {
        _fromDate = value;
        _request.FromDate = value;
        return Task.CompletedTask;
    }

    private Task OnToDateChanged(DateTime? value)
    {
        _toDate = value;
        _request.ToDate = value;
        return Task.CompletedTask;
    }

    private async Task OnPageSizeChangedAsync(int value)
    {
        if (_request.PageSize == value)
            return;

        _request.PageSize = value;
        _request.PageNumber = 1;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_data.Entries.PageSize == -1 || _data.Entries.PageNumber <= 1)
            return;

        _request.PageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_data.Entries.PageSize == -1 || _data.Entries.PageNumber >= _totalPages)
            return;

        _request.PageNumber++;
        await LoadAsync();
    }

    private string GetPagingText()
    {
        if (_data.Entries.TotalCount == 0)
            return "No records";

        if (_data.Entries.PageSize == -1)
            return $"Showing all {_data.Entries.TotalCount} record(s)";

        var start = ((_data.Entries.PageNumber - 1) * _data.Entries.PageSize) + 1;
        var end = Math.Min(_data.Entries.PageNumber * _data.Entries.PageSize, _data.Entries.TotalCount);

        return $"Showing {start}-{end} of {_data.Entries.TotalCount} • Page {_data.Entries.PageNumber} of {_totalPages}";
    }

    private void GoToFeesDashboard()
    {
        Navigation.NavigateTo("/tenant/fees/dashboard");
    }

    private static string DisplayText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static Color GetEntryTypeColor(string? type) => type switch
    {
        "Charge" => Color.Warning,
        "Discount" => Color.Success,
        "Fine" => Color.Error,
        "Receipt" => Color.Primary,
        "ReceiptCancel" => Color.Secondary,
        "Adjustment" => Color.Info,
        _ => Color.Default
    };
}