@page "/tenant/fees/dashboard"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.Fees
@using Shala.Shared.Responses.Fees
@using Shala.Web.Repositories.Fees

@inject IFeeWebRepository FeeRepo
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Fees Dashboard</PageTitle>

@if (_loading)
{
    <MudPaper Class="pa-8 d-flex justify-center align-center" Elevation="0">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading fees dashboard...</MudText>
        </MudStack>
    </MudPaper>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
        @_error
    </MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="pa-5 pa-md-6" Elevation="2" Style="border-radius: 20px; background: linear-gradient(135deg, rgba(25,118,210,0.10), rgba(76,175,80,0.10));">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" lg="8">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h4">Fees Dashboard</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Monitor assignment coverage, collectible students, and admission-level fee workflow from one screen.
                                </MudText>
                            </div>
                        </MudStack>

                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                Students: @_data.Students.TotalCount
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small">
                                Assigned: @_data.Summary.AssignedPlans
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small">
                                Collectible: @_data.Summary.CollectibleStudents
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small">
                                Paid: @_data.Summary.FullyPaidStudents
                            </MudChip>
                        </MudStack>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudStack AlignItems="AlignItems.End" Spacing="1">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.MenuBook"
                                   OnClick="GoToLedger">
                            Open Ledger
                        </MudButton>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Open an admission row to manage assignment, charges, receipts, and collection.
                        </MudText>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Amount</MudText>
                    <MudText Typo="Typo.h5">@_data.Summary.TotalAmount.ToString("N2")</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Collected</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success">@_data.Summary.TotalPaid.ToString("N2")</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Outstanding</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Error">@_data.Summary.TotalBalance.ToString("N2")</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" lg="3">
                <MudPaper Class="pa-4 h-100" Elevation="1" Style="border-radius:16px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Coverage</MudText>
                    <MudText Typo="Typo.h5">@GetCoveragePercent().ToString("0.##")%</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assignments / students</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4" Elevation="1" Style="border-radius:18px;">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Label="Search"
                                  Placeholder="Student name, admission no, roll no"
                                  @bind-Value="_request.SearchText"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudSelect T="string"
                               Label="Workflow Status"
                               @bind-Value="_request.WorkflowStatus"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem T="string" Value="@("Plan Missing")">Plan Missing</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Charges Pending")">Charges Pending</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Collectible")">Collectible</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Partial")">Partial</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Paid")">Paid</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="2">
                    <MudSelect T="int"
                               Label="Rows"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Value="_request.PageSize"
                               ValueChanged="OnPageSizeChangedAsync">
                        <MudSelectItem T="int" Value="10">10</MudSelectItem>
                        <MudSelectItem T="int" Value="25">25</MudSelectItem>
                        <MudSelectItem T="int" Value="50">50</MudSelectItem>
                        <MudSelectItem T="int" Value="100">100</MudSelectItem>
                        <MudSelectItem T="int" Value="-1">All</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="3" Class="d-flex align-end">
                    <MudStack Row="true" Spacing="1" Class="w-100">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SearchAsync">
                            Search
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetAsync">
                            Reset
                        </MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-0" Elevation="1" Style="border-radius:18px; overflow:hidden;">
            <MudTable T="FeeDashboardRowResponse"
                      Items="_data.Students.Items"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Student</MudTh>
                    <MudTh>Academic</MudTh>
                    <MudTh>Plan</MudTh>
                    <MudTh Align="right">Total</MudTh>
                    <MudTh Align="right">Paid</MudTh>
                    <MudTh Align="right">Balance</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Align="right">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Student">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2">@context.StudentName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Admission: @context.AdmissionNo
                                @if (!string.IsNullOrWhiteSpace(context.RollNo))
                                {
                                    <span> | Roll: @context.RollNo</span>
                                }
                            </MudText>
                        </MudStack>
                    </MudTd>

                    <MudTd DataLabel="Academic">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@context.ClassName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @context.AcademicYear
                                @if (!string.IsNullOrWhiteSpace(context.SectionName))
                                {
                                    <span> | @context.SectionName</span>
                                }
                            </MudText>
                        </MudStack>
                    </MudTd>

                    <MudTd DataLabel="Plan">
                        @if (string.IsNullOrWhiteSpace(context.FeeStructureName))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Not Assigned</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.FeeStructureName</MudText>
                        }
                    </MudTd>

                    <MudTd DataLabel="Total" Align="right">
                        @context.TotalAmount.ToString("N2")
                    </MudTd>

                    <MudTd DataLabel="Paid" Align="right">
                        @context.TotalPaid.ToString("N2")
                    </MudTd>

                    <MudTd DataLabel="Balance" Align="right">
                        <MudText Color="@(context.TotalBalance > 0 ? Color.Error : Color.Success)">
                            @context.TotalBalance.ToString("N2")
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Variant="Variant.Filled"
                                 Size="Size.Small"
                                 Color="@GetWorkflowColor(context.WorkflowStatus)">
                            @context.WorkflowStatus
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Actions" Align="right">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   OnClick="@(() => OpenAdmissionWorkspace(context))">
                            Open
                        </MudButton>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <div class="pa-6">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Info">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">No student fee records found</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Adjust search or workflow filters and try again.
                            </MudText>
                        </MudStack>
                    </div>
                </NoRecordsContent>
            </MudTable>

            <MudDivider />

            <div class="pa-4">
                <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @GetPagingText()
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" md="6" Class="d-flex justify-end">
                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Outlined"
                                       Disabled="@(_data.Students.PageSize == -1 || _data.Students.PageNumber <= 1)"
                                       OnClick="PreviousPageAsync">
                                Prev
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Disabled="@(_data.Students.PageSize == -1 || _data.Students.PageNumber >= _totalPages)"
                                       OnClick="NextPageAsync">
                                Next
                            </MudButton>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>
    </MudStack>
}

@code {
    private readonly FeeDashboardRequest _request = new()
    {
        PageNumber = 1,
        PageSize = 25
    };

    private FeeDashboardResponse _data = new();
    private bool _loading = true;
    private string? _error;

    private int _totalPages => _data.Students.PageSize <= 0 || _data.Students.TotalCount <= 0
        ? 1
        : (int)Math.Ceiling((double)_data.Students.TotalCount / _data.Students.PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            _data = await FeeRepo.GetDashboardAsync(_request);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        _request.PageNumber = 1;
        await LoadAsync();
    }

    private async Task ResetAsync()
    {
        _request.SearchText = null;
        _request.WorkflowStatus = null;
        _request.PageNumber = 1;
        _request.PageSize = 25;
        await LoadAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _request.PageSize = size;
        _request.PageNumber = 1;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_request.PageSize == -1 || _request.PageNumber <= 1)
            return;

        _request.PageNumber--;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_request.PageSize == -1 || _request.PageNumber >= _totalPages)
            return;

        _request.PageNumber++;
        await LoadAsync();
    }

    private void OpenAdmissionWorkspace(FeeDashboardRowResponse row)
    {
        Navigation.NavigateTo($"/tenant/students/{row.StudentId}/admissions/{row.AdmissionId}/fees");
    }

    private void GoToLedger()
    {
        Navigation.NavigateTo("/tenant/ledger");
    }

    private double GetCoveragePercent()
    {
        if (_data.Summary.TotalStudents <= 0)
            return 0;

        var value = (_data.Summary.AssignedPlans / (decimal)_data.Summary.TotalStudents) * 100m;
        return (double)Math.Min(100m, Math.Max(0m, value));
    }

    private static Color GetWorkflowColor(string? workflowStatus)
    {
        return workflowStatus?.Trim() switch
        {
            "Plan Missing" => Color.Default,
            "Charges Pending" => Color.Info,
            "Collectible" => Color.Warning,
            "Partial" => Color.Secondary,
            "Paid" => Color.Success,
            _ => Color.Primary
        };
    }

    private string GetPagingText()
    {
        if (_data.Students.TotalCount <= 0)
            return "No records";

        if (_data.Students.PageSize == -1)
            return $"Showing all {_data.Students.TotalCount} records";

        var start = ((_data.Students.PageNumber - 1) * _data.Students.PageSize) + 1;
        var end = Math.Min(_data.Students.PageNumber * _data.Students.PageSize, _data.Students.TotalCount);

        return $"Showing {start}-{end} of {_data.Students.TotalCount} records";
    }
}