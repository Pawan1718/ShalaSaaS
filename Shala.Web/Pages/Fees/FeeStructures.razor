
@page "/tenant/settings/fees/structures"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Responses.Fees
@using Shala.Shared.Responses.Academics
@using Shala.Web.Components.Common
@using Shala.Web.Components.Fees
@using Shala.Web.Repositories.Fees
@using Shala.Web.Repositories.AcademicRepo
@using Shala.Web.Services.State

@inject IFeeWebRepository FeeWebRepository
@inject IAcademicYearRepository AcademicYearRepository
@inject IAcademicClassRepository AcademicClassRepository
@inject ApiSession ApiSession
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Fee Structures</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppPageHeader Title="Fee Structures"
                   Subtitle="Create and manage class-wise fee structures">
        <Actions>
            <AppButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@_loading"
                       OnClick="@((MouseEventArgs _) => LoadAsync())">
                Refresh
            </AppButton>

            <AppButton StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@(_loading || !_feeHeads.Any())"
                       OnClick="@((MouseEventArgs _) => OpenCreateDialogAsync())">
                Add Structure
            </AppButton>
        </Actions>
    </AppPageHeader>

    @if (!_feeHeads.Any() && !_loading && string.IsNullOrWhiteSpace(_error))
    {
        <AppError Message="No fee heads found. Please create fee heads first."
                  Severity="Severity.Warning"
                  Class="mb-3" />
    }

    <AppToolbar>
        <Filters>
            <div class="structure-search">
                <AppSearchBox Label="Search"
                              Placeholder="Search structure name"
                              Value="@_searchText"
                              ValueChanged="OnSearchChanged" />
            </div>

            <MudSwitch T="bool"
                       Label="Show inactive"
                       Color="Color.Primary"
                       Value="@_showInactive"
                       ValueChanged="OnShowInactiveChanged" />
        </Filters>
    </AppToolbar>

    <AppTableCard TItem="FeeStructureResponse"
                  Title="Fee Structure List"
                  Subtitle="@($"{_filteredStructures.Count} record(s)")"
                  IsLoading="@_loading"
                  ErrorMessage="@_error"
                  IsEmpty="@(!_loading && !_filteredStructures.Any())"
                  EmptyTitle="No structures found"
                  EmptyMessage="Create a structure or adjust filters.">

        <ChildContent>
            <MudTable T="FeeStructureResponse"
                      Items="@_filteredStructures"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm">

                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Academic Year</MudTh>
                    <MudTh>Class</MudTh>
                    <MudTh>Items</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Align="Align.Right">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Academic Year">@GetAcademicYearName(context.AcademicYearId)</MudTd>
                    <MudTd DataLabel="Class">@GetAcademicClassName(context.AcademicClassId)</MudTd>
                    <MudTd DataLabel="Items">@context.Items.Count</MudTd>

                    <MudTd DataLabel="Status">
                        <StatusChip IsActive="@context.IsActive"
                                    ActiveText="Active"
                                    InactiveText="Inactive"
                                    ActiveColor="Color.Success"
                                    InactiveColor="Color.Error" />
                    </MudTd>

                    <MudTd DataLabel="Actions" Align="Align.Right">
                        <AppActionMenu OnView="@(() => OpenViewDialogAsync(context.Id))"
                                       OnEdit="@(() => OpenEditDialogAsync(context.Id))"
                                       OnDelete="@(() => ConfirmDeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </ChildContent>
    </AppTableCard>
</AppPageShell>

@code {
    private bool _loading = true;
    private string? _error;
    private string _searchText = string.Empty;
    private bool _showInactive;

    private List<FeeStructureResponse> _structures = new();
    private List<FeeStructureResponse> _filteredStructures = new();
    private List<FeeHeadResponse> _feeHeads = new();

    private List<dynamic> _academicYears = new();
    private List<dynamic> _academicClasses = new();

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", "/tenant/dashboard"),
        new("Fee Structures", null, true)
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            await ApiSession.InitializeAsync();

            var tenantId = ApiSession.TenantId;
            if (!tenantId.HasValue || tenantId.Value <= 0)
            {
                _error = "Tenant context not found.";
                return;
            }

            _feeHeads = await FeeWebRepository.GetFeeHeadsAsync();
            _structures = await FeeWebRepository.GetFeeStructuresAsync();

            var academicYearResponse = await AcademicYearRepository.GetAllAsync(tenantId.Value);
            if (academicYearResponse?.Success == true && academicYearResponse.Data is not null)
                _academicYears = academicYearResponse.Data.Cast<dynamic>().ToList();

            var academicClassResponse = await AcademicClassRepository.GetAllAsync(tenantId.Value);
            if (academicClassResponse?.Success == true && academicClassResponse.Data is not null)
                _academicClasses = academicClassResponse.Data.Cast<dynamic>().ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnSearchChanged(string? value)
    {
        _searchText = value ?? string.Empty;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnShowInactiveChanged(bool value)
    {
        _showInactive = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void ApplyFilters()
    {
        IEnumerable<FeeStructureResponse> query = _structures;

        if (!_showInactive)
            query = query.Where(x => x.IsActive);

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();

            query = query.Where(x =>
                x.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Description) &&
                 x.Description.Contains(term, StringComparison.OrdinalIgnoreCase)));
        }

        _filteredStructures = query
            .OrderBy(x => x.Name)
            .ToList();
    }

    private string GetAcademicYearName(int academicYearId)
    {
        var item = _academicYears.FirstOrDefault(x => x.Id == academicYearId);
        return item?.Name ?? $"#{academicYearId}";
    }

    private string GetAcademicClassName(int academicClassId)
    {
        var item = _academicClasses.FirstOrDefault(x => x.Id == academicClassId);
        return item?.Name ?? $"#{academicClassId}";
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<FeeStructureDialog>(
            "Add Fee Structure",
            new DialogParameters
            {
                [nameof(FeeStructureDialog.IsReadOnly)] = false,
                [nameof(FeeStructureDialog.AvailableFeeHeads)] = _feeHeads
            },
            new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task OpenViewDialogAsync(int id)
    {
        try
        {
            var structure = await FeeWebRepository.GetFeeStructureByIdAsync(id);

            if (structure is null)
            {
                Snackbar.Add("Fee structure not found.", Severity.Warning);
                return;
            }

            var dialog = await DialogService.ShowAsync<FeeStructureDialog>(
                "View Fee Structure",
                new DialogParameters
                {
                    [nameof(FeeStructureDialog.IsReadOnly)] = true,
                    [nameof(FeeStructureDialog.Structure)] = structure,
                    [nameof(FeeStructureDialog.AvailableFeeHeads)] = _feeHeads
                },
                new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });

            await dialog.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenEditDialogAsync(int id)
    {
        try
        {
            var structure = await FeeWebRepository.GetFeeStructureByIdAsync(id);

            if (structure is null)
            {
                Snackbar.Add("Fee structure not found.", Severity.Warning);
                return;
            }

            var dialog = await DialogService.ShowAsync<FeeStructureDialog>(
                "Edit Fee Structure",
                new DialogParameters
                {
                    [nameof(FeeStructureDialog.IsReadOnly)] = false,
                    [nameof(FeeStructureDialog.Structure)] = structure,
                    [nameof(FeeStructureDialog.AvailableFeeHeads)] = _feeHeads
                },
                new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });

            var result = await dialog.Result;

            if (!result.Canceled)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync(int id, string name)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Delete Fee Structure",
            new DialogParameters
            {
                [nameof(ConfirmDialog.Title)] = "Delete Fee Structure",
                [nameof(ConfirmDialog.Message)] = $"Are you sure you want to delete '{name}'?",
                [nameof(ConfirmDialog.ConfirmText)] = "Delete",
                [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
            },
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        var result = await dialog.Result;

        if (result.Canceled)
            return;

        try
        {
            await FeeWebRepository.DeleteFeeStructureAsync(id);
            Snackbar.Add("Fee structure deleted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}