


@page "/tenant/settings/fees/heads"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Responses.Fees
@using Shala.Web.Components.Common
@using Shala.Web.Components.Fees
@using Shala.Web.Repositories.Fees

@inject IFeeWebRepository FeeWebRepository
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Fee Heads</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppPageHeader Title="Fee Heads"
                   Subtitle="Manage fee heads like Admission Fee, Tuition Fee, Annual Fee">
        <Actions>
            <AppButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@_loading"
                       OnClick="@((MouseEventArgs _) => LoadAsync())">
                Refresh
            </AppButton>

            <AppButton StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@_loading"
                       OnClick="@((MouseEventArgs _) => OpenCreateDialogAsync())">
                Add Fee Head
            </AppButton>
        </Actions>
    </AppPageHeader>

    <AppToolbar>
        <Filters>
            <div class="fee-heads-search">
                <AppSearchBox Label="Search"
                              Placeholder="Search by name or code"
                              Value="@_searchText"
                              ValueChanged="OnSearchChanged" />
            </div>

            <MudSwitch T="bool"
                       Label="Show inactive"
                       Color="Color.Primary"
                       Value="@_showInactive"
                       ValueChanged="OnShowInactiveChanged" />
        </Filters>
    </AppToolbar>

    <AppTableCard TItem="FeeHeadResponse"
                  Title="Fee Head List"
                  Subtitle="@($"{_filteredFeeHeads.Count} record(s)")"
                  IsLoading="@_loading"
                  ErrorMessage="@_error"
                  IsEmpty="@(!_loading && !_filteredFeeHeads.Any())"
                  EmptyTitle="No fee heads found"
                  EmptyMessage="Create a fee head or change search/filter.">
        <ChildContent>
            <MudTable T="FeeHeadResponse"
                      Items="@_filteredFeeHeads"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm">

                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Code</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Registration Fee</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Align="Align.Right">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="Code">@context.Code</MudTd>
                    <MudTd DataLabel="Description">
                        @(string.IsNullOrWhiteSpace(context.Description) ? "-" : context.Description)
                    </MudTd>

                    <MudTd DataLabel="Registration Fee">
                        <StatusChip IsActive="@context.IsRegistrationFee"
                                    ActiveText="Yes"
                                    InactiveText="No"
                                    ActiveColor="Color.Info"
                                    InactiveColor="Color.Default" />
                    </MudTd>

                    <MudTd DataLabel="Status">
                        <StatusChip IsActive="@context.IsActive"
                                    ActiveText="Active"
                                    InactiveText="Inactive"
                                    ActiveColor="Color.Success"
                                    InactiveColor="Color.Error" />
                    </MudTd>

                    <MudTd DataLabel="Actions" Align="Align.Right">
                        <AppActionMenu OnEdit="@(() => OpenEditDialogAsync(context.Id))"
                                       OnDelete="@(() => ConfirmDeleteAsync(context.Id, context.Name))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </ChildContent>
    </AppTableCard>
</AppPageShell>

@code {
    private bool _loading = true;
    private string? _error;
    private string _searchText = string.Empty;
    private bool _showInactive;

    private List<FeeHeadResponse> _feeHeads = new();
    private List<FeeHeadResponse> _filteredFeeHeads = new();

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", "/tenant/dashboard"),
        new("Fee Heads", null, true)
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;

            _feeHeads = await FeeWebRepository.GetFeeHeadsAsync();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Task OnSearchChanged(string? value)
    {
        _searchText = value ?? string.Empty;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnShowInactiveChanged(bool value)
    {
        _showInactive = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void ApplyFilters()
    {
        IEnumerable<FeeHeadResponse> query = _feeHeads;

        if (!_showInactive)
            query = query.Where(x => x.IsActive);

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var term = _searchText.Trim();

            query = query.Where(x =>
                x.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                x.Code.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrWhiteSpace(x.Description) &&
                 x.Description.Contains(term, StringComparison.OrdinalIgnoreCase)));
        }

        _filteredFeeHeads = query
            .OrderBy(x => x.Name)
            .ToList();
    }

    private async Task OpenCreateDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<FeeHeadDialog>(
            "Add Fee Head",
            new DialogParameters
            {
                [nameof(FeeHeadDialog.IsEdit)] = false
            },
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private async Task OpenEditDialogAsync(int id)
    {
        try
        {
            var feeHead = await FeeWebRepository.GetFeeHeadByIdAsync(id);

            if (feeHead is null)
            {
                Snackbar.Add("Fee head not found.", Severity.Warning);
                return;
            }

            var dialog = await DialogService.ShowAsync<FeeHeadDialog>(
                "Edit Fee Head",
                new DialogParameters
                {
                    [nameof(FeeHeadDialog.IsEdit)] = true,
                    [nameof(FeeHeadDialog.FeeHead)] = feeHead
                },
                new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

            var result = await dialog.Result;

            if (!result.Canceled)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ConfirmDeleteAsync(int id, string name)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Delete Fee Head",
            new DialogParameters
            {
                [nameof(ConfirmDialog.Title)] = "Delete Fee Head",
                [nameof(ConfirmDialog.Message)] = $"Are you sure you want to delete '{name}'?",
                [nameof(ConfirmDialog.ConfirmText)] = "Delete",
                [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
            },
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        var result = await dialog.Result;

        if (result.Canceled)
            return;

        try
        {
            await FeeWebRepository.DeleteFeeHeadAsync(id);
            Snackbar.Add("Fee head deleted successfully.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}