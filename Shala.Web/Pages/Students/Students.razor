@page "/tenant/students"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Common
@using Shala.Shared.Requests.Students
@using Shala.Shared.Responses.Students
@using Shala.Web.Components.Common
@using Shala.Web.Repositories.Interfaces
@using Shala.Web.Services.State

@inject IStudentRepository StudentRepository
@inject IStudentLookupRepository StudentLookupRepository
@inject ApiSession Session
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

@layout Components.Layouts.TenantMainLayout

<PageTitle>Students</PageTitle>

<AppPageShell>
    <AppPageHeader Title="Student Management"
                   Subtitle="Manage student records, academic placement and class-wise filtering">
        <Actions>
            <AppButton StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="@((MouseEventArgs _) => GoToCreate())">
                Add Student
            </AppButton>
        </Actions>
    </AppPageHeader>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Total Students"
                         Value="@_totalCount.ToString()"
                         Icon="@Icons.Material.Filled.Groups" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Academic Years"
                         Value="@_academicYears.Count.ToString()"
                         Icon="@Icons.Material.Filled.CalendarMonth"
                         Color="Color.Secondary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Classes"
                         Value="@_classes.Count.ToString()"
                         Icon="@Icons.Material.Filled.School"
                         Color="Color.Info" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Sections"
                         Value="@_sections.Count.ToString()"
                         Icon="@Icons.Material.Filled.AccountTree"
                         Color="Color.Warning" />
        </MudItem>
    </MudGrid>

    <AppToolbar>
        <Filters>
            <MudTextField T="string"
                          Label="Search student"
                          Placeholder="Name, admission no, mobile..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          DebounceInterval="300"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Style="min-width:280px;"
                          @bind-Value="_request.Search" />

            <MudSelect T="int?"
                       Label="Academic Year"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width:170px;"
                       @bind-Value="_request.AcademicYearId">
                <MudSelectItem T="int?" Value="@((int?)null)">All</MudSelectItem>
                @foreach (var item in _academicYears)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?"
                       Label="Class"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width:150px;"
                       Value="_request.ClassId"
                       ValueChanged="OnClassChanged">
                <MudSelectItem T="int?" Value="@((int?)null)">All</MudSelectItem>
                @foreach (var item in _classes)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?"
                       Label="Section"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width:150px;"
                       @bind-Value="_request.SectionId"
                       Disabled="@(!_request.ClassId.HasValue)">
                <MudSelectItem T="int?" Value="@((int?)null)">All</MudSelectItem>
                @foreach (var item in _sections)
                {
                    <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                }
            </MudSelect>
        </Filters>

        <Actions>
            <AppButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="@(async (MouseEventArgs _) => await ResetFiltersAsync())">
                Reset
            </AppButton>

            <AppButton StartIcon="@Icons.Material.Filled.Search"
                       OnClick="@(async (MouseEventArgs _) => await SearchAsync())">
                Search
            </AppButton>
        </Actions>
    </AppToolbar>

    <AppCard PaddingClass="pa-0" Class="overflow-hidden">
        <div class="shala-table-header">
            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Wrap="Wrap.Wrap"
                      Spacing="2">
                <div>
                    <MudText Typo="Typo.subtitle1" Class="fw-semibold">Students</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Showing student records from current filters
                    </MudText>
                </div>

                <MudSelect T="int"
                           Label="Rows"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Dense="true"
                           Style="width:110px"
                           Value="_request.PageSize"
                           ValueChanged="OnPageSizeChanged">
                    <MudSelectItem T="int" Value="10">10</MudSelectItem>
                    <MudSelectItem T="int" Value="25">25</MudSelectItem>
                    <MudSelectItem T="int" Value="50">50</MudSelectItem>
                    <MudSelectItem T="int" Value="100">100</MudSelectItem>
                </MudSelect>
            </MudStack>
        </div>

        <MudDivider />

        <MudTable T="StudentListItemResponse"
                  Items="_students"
                  Hover="true"
                  Dense="true"
                  Striped="true"
                  Loading="_loading"
                  Breakpoint="Breakpoint.Md"
                  Class="shala-table">

            <HeaderContent>
                <MudTh>Admission No</MudTh>
                <MudTh>Student</MudTh>
                <MudTh>Gender</MudTh>
                <MudTh>Mobile</MudTh>
                <MudTh>Academic Year</MudTh>
                <MudTh>Class</MudTh>
                <MudTh>Section</MudTh>
                <MudTh>Status</MudTh>
                <MudTh Align="Align.Right">Actions</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="Admission No">
                    <MudText Typo="Typo.body2" Class="fw-semibold brand-text">
                        @context.AdmissionNo
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Student">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2" Class="fw-semibold">@context.FullName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.CurrentClass @context.CurrentSection
                        </MudText>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="Gender">@context.Gender</MudTd>
                <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
                <MudTd DataLabel="Academic Year">@context.CurrentAcademicYear</MudTd>
                <MudTd DataLabel="Class">@context.CurrentClass</MudTd>
                <MudTd DataLabel="Section">@context.CurrentSection</MudTd>

                <MudTd DataLabel="Status">
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="Variant.Filled"
                             Color="@GetStatusColor(context.Status)">
                        @context.Status
                    </MudChip>
                </MudTd>

                <MudTd DataLabel="Actions" Align="Align.Right">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true">
                        <MudMenuItem Icon="@Icons.Material.Filled.Visibility"
                                     OnClick="@(() => GoToDetails(context.Id))">
                            View Details
                        </MudMenuItem>
                    </MudMenu>
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <AppEmptyState Title="No students found"
                               Message="Filters change karo ya first student add karo."
                               Icon="@Icons.Material.Filled.Groups"
                               IconColor="Color.Secondary">
                    <Actions>
                        <AppButton StartIcon="@Icons.Material.Filled.PersonAdd"
                                   OnClick="@((MouseEventArgs _) => GoToCreate())">
                            Add Student
                        </AppButton>
                    </Actions>
                </AppEmptyState>
            </NoRecordsContent>
        </MudTable>

        <MudDivider />

        <div class="shala-table-footer">
            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Wrap="Wrap.Wrap"
                      Spacing="2">

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Page @_request.PageNumber of @_totalPages • Total @_totalCount
                </MudText>

                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.NavigateBefore"
                               Disabled="@(_request.PageNumber <= 1 || _loading)"
                               OnClick="PreviousPage">
                        Prev
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               EndIcon="@Icons.Material.Filled.NavigateNext"
                               Disabled="@(_request.PageNumber >= _totalPages || _loading)"
                               OnClick="NextPage">
                        Next
                    </MudButton>
                </MudStack>
            </MudStack>
        </div>
    </AppCard>
</AppPageShell>

<style>
    .fw-semibold {
        font-weight: 600;
    }

    .brand-text {
        color: #0B2A4A;
    }

    .shala-table-header {
        padding: 16px;
        background: #FFFFFF;
    }

    .shala-table-footer {
        padding: 14px 16px;
        background: #FFFFFF;
    }

    .shala-table .mud-table-head {
        background: #F7F9FB;
    }

    .shala-table .mud-table-cell {
        border-bottom: 1px solid #E5EAF0;
    }

    .overflow-hidden {
        overflow: hidden;
    }
</style>

@code {
    private readonly StudentListRequest _request = new();
    private List<StudentListItemResponse> _students = [];
    private List<LookupItemResponse> _academicYears = [];
    private List<LookupItemResponse> _classes = [];
    private List<LookupItemResponse> _sections = [];

    private bool _loading;
    private int _totalCount;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        _request.PageNumber = Math.Max(1, _request.PageNumber);
        _request.PageSize = _request.PageSize <= 0 ? 10 : _request.PageSize;

        await LoadInitialDataAsync();
    }

    private async Task LoadInitialDataAsync()
    {
        try
        {
            _loading = true;

            await Session.InitializeAsync();

            if (!Session.TenantId.HasValue || !Session.BranchId.HasValue)
            {
                Snackbar.Add("Tenant or Branch context is missing.", Severity.Error);
                return;
            }

            await LoadLookupsAsync();
            await LoadStudentsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            if (!Session.TenantId.HasValue || !Session.BranchId.HasValue)
                return;

            var tenantId = Session.TenantId.Value;
            var branchId = Session.BranchId.Value;

            var academicYearsResponse = await StudentLookupRepository.GetAcademicYearsAsync(tenantId);
            _academicYears = academicYearsResponse?.Success == true && academicYearsResponse.Data is not null
                ? academicYearsResponse.Data
                : [];

            var classesResponse = await StudentLookupRepository.GetClassesAsync(tenantId);
            _classes = classesResponse?.Success == true && classesResponse.Data is not null
                ? classesResponse.Data
                : [];

            if (_request.ClassId.HasValue)
            {
                var sectionsResponse = await StudentLookupRepository.GetSectionsByClassAsync(
                    tenantId,
                    branchId,
                    _request.ClassId.Value);

                _sections = sectionsResponse?.Success == true && sectionsResponse.Data is not null
                    ? sectionsResponse.Data
                    : [];
            }
            else
            {
                _sections = [];
            }
        }
        catch (Exception ex)
        {
            _academicYears = [];
            _classes = [];
            _sections = [];
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task LoadStudentsAsync()
    {
        try
        {
            _loading = true;

            var response = await StudentRepository.GetPagedAsync(_request);

            if (response?.Success == true && response.Data is not null)
            {
                _students = response.Data.Items.ToList();
                _totalCount = response.Data.TotalCount;
                _totalPages = Math.Max(1, (int)Math.Ceiling((double)_totalCount / _request.PageSize));

                if (_request.PageNumber > _totalPages)
                {
                    _request.PageNumber = 1;
                    await LoadStudentsAsync();
                }
            }
            else
            {
                _students = [];
                _totalCount = 0;
                _totalPages = 1;
                Snackbar.Add(response?.Message ?? "Failed to load students.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _students = [];
            _totalCount = 0;
            _totalPages = 1;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        _request.PageNumber = 1;
        await LoadStudentsAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _request.Search = null;
        _request.AcademicYearId = null;
        _request.ClassId = null;
        _request.SectionId = null;
        _request.PageNumber = 1;
        _sections = [];

        await LoadStudentsAsync();
    }

    private async Task OnClassChanged(int? value)
    {
        _request.ClassId = value;
        _request.SectionId = null;
        _sections = [];

        try
        {
            if (!value.HasValue || !Session.TenantId.HasValue || !Session.BranchId.HasValue)
                return;

            var response = await StudentLookupRepository.GetSectionsByClassAsync(
                Session.TenantId.Value,
                Session.BranchId.Value,
                value.Value);

            if (response?.Success == true && response.Data is not null)
                _sections = response.Data;
        }
        catch (Exception ex)
        {
            _sections = [];
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OnPageSizeChanged(int value)
    {
        _request.PageSize = value;
        _request.PageNumber = 1;
        await LoadStudentsAsync();
    }

    private async Task PreviousPage()
    {
        if (_request.PageNumber <= 1)
            return;

        _request.PageNumber--;
        await LoadStudentsAsync();
    }

    private async Task NextPage()
    {
        if (_request.PageNumber >= _totalPages)
            return;

        _request.PageNumber++;
        await LoadStudentsAsync();
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/tenant/students/create");
    }

    private void GoToDetails(int id)
    {
        Navigation.NavigateTo($"/tenant/students/{id}");
    }

    private static Color GetStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "active" => Color.Success,
            "inactive" => Color.Warning,
            "left" => Color.Error,
            "suspended" => Color.Error,
            _ => Color.Default
        };
    }
}