
@page "/tenant/students"

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Common
@using Shala.Shared.Requests.Students
@using Shala.Shared.Responses.Students
@using Shala.Web.Components.Common
@using Shala.Web.Repositories.Interfaces
@using Shala.Web.Services.State

@inject IStudentRepository StudentRepository
@inject IStudentLookupRepository StudentLookupRepository
@inject ApiSession Session
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

@layout Components.Layouts.TenantMainLayout

<PageTitle>Students</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppPageHeader Title="Students"
                   Subtitle="Manage student records, class, section and admission details">
        <Actions>
            <AppButton StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="@((MouseEventArgs _) => GoToCreate())">
                Add Student
            </AppButton>
        </Actions>
    </AppPageHeader>

    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Total Students"
                         Value="@_totalCount.ToString()"
                         Icon="@Icons.Material.Filled.Groups" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Academic Years"
                         Value="@_academicYears.Count.ToString()"
                         Icon="@Icons.Material.Filled.CalendarMonth"
                         Color="Color.Secondary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Classes"
                         Value="@_classes.Count.ToString()"
                         Icon="@Icons.Material.Filled.School"
                         Color="Color.Info" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <AppStatCard Label="Sections"
                         Value="@_sections.Count.ToString()"
                         Icon="@Icons.Material.Filled.AccountTree"
                         Color="Color.Warning" />
        </MudItem>
    </MudGrid>

    <AppToolbar>
        <Filters>
            <div class="students-search">
                <AppSearchBox Label="Search"
                              Placeholder="Search name, admission no, mobile..."
                              @bind-Value="_request.Search" />
            </div>

            <AppFilterSelect TValue="int?"
                             TItem="LookupItemResponse"
                             Label="Academic Year"
                             Value="@_request.AcademicYearId"
                             ValueChanged="OnAcademicYearChanged"
                             Items="@_academicYears"
                             ValueSelector="@(x => (int?)x.Id)"
                             TextSelector="@(x => x.Name)" />

            <AppFilterSelect TValue="int?"
                             TItem="LookupItemResponse"
                             Label="Class"
                             Value="@_request.ClassId"
                             ValueChanged="OnClassChanged"
                             Items="@_classes"
                             ValueSelector="@(x => (int?)x.Id)"
                             TextSelector="@(x => x.Name)" />

            <AppFilterSelect TValue="int?"
                             TItem="LookupItemResponse"
                             Label="Section"
                             Value="@_request.SectionId"
                             ValueChanged="OnSectionChanged"
                             Items="@_sections"
                             ValueSelector="@(x => (int?)x.Id)"
                             TextSelector="@(x => x.Name)" />
        </Filters>

        <Actions>
            <AppButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@_loading"
                       OnClick="@(async (MouseEventArgs _) => await ResetFiltersAsync())">
                Reset
            </AppButton>

            <AppButton StartIcon="@Icons.Material.Filled.Search"
                       Disabled="@_loading"
                       OnClick="@(async (MouseEventArgs _) => await SearchAsync())">
                Search
            </AppButton>
        </Actions>
    </AppToolbar>

    <AppTableCard TItem="StudentListItemResponse"
                  Title="Student List"
                  Subtitle="Showing students based on selected filters"
                  IsLoading="@_loading"
                  ErrorMessage="@_errorMessage"
                  IsEmpty="@(!_loading && !_students.Any())"
                  EmptyTitle="No students found"
                  EmptyMessage="Try changing filters or add a new student.">

        <Actions>
            <AppFilterSelect TValue="int"
                             TItem="int"
                             Label="Rows"
                             Value="@_request.PageSize"
                             ValueChanged="OnPageSizeChanged"
                             Items="@_pageSizeOptions"
                             ValueSelector="@(x => x)"
                             TextSelector="@(x => x.ToString())" />
        </Actions>

        <EmptyActions>
            <AppButton StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="@((MouseEventArgs _) => GoToCreate())">
                Add Student
            </AppButton>
        </EmptyActions>

        <ChildContent>
            <MudTable T="StudentListItemResponse"
                      Items="@_students"
                      Hover="true"
                      Dense="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Md"
                      Class="students-table">

                <HeaderContent>
                    <MudTh>Admission No</MudTh>
                    <MudTh>Student</MudTh>
                    <MudTh>Gender</MudTh>
                    <MudTh>Mobile</MudTh>
                    <MudTh>Academic Year</MudTh>
                    <MudTh>Class</MudTh>
                    <MudTh>Section</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Align="right">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Admission No">
                        <MudText Typo="Typo.body2" Class="fw-semibold brand-text">
                            @context.AdmissionNo
                        </MudText>
                    </MudTd>

                    <MudTd DataLabel="Student">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Class="fw-semibold">
                                @context.FullName
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @context.CurrentClass @context.CurrentSection
                            </MudText>
                        </MudStack>
                    </MudTd>

                    <MudTd DataLabel="Gender">@context.Gender</MudTd>
                    <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
                    <MudTd DataLabel="Academic Year">@context.CurrentAcademicYear</MudTd>
                    <MudTd DataLabel="Class">@context.CurrentClass</MudTd>
                    <MudTd DataLabel="Section">@context.CurrentSection</MudTd>

                    <MudTd DataLabel="Status">
                        <StatusChip IsActive="@IsActiveStatus(context.Status)"
                                    ActiveText="@GetStatusText(context.Status)"
                                    InactiveText="@GetStatusText(context.Status)"
                                    ActiveColor="Color.Success"
                                    InactiveColor="@GetStatusColor(context.Status)" />
                    </MudTd>

                    <MudTd DataLabel="Actions" Align="right">
                        <AppButton Variant="Variant.Text"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   OnClick="@((MouseEventArgs _) => GoToDetails(context.Id))">
                            Open
                        </AppButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </ChildContent>

        <Footer>
            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Wrap="Wrap.Wrap"
                      Spacing="2">

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Page @_request.PageNumber of @_totalPages • Total @_totalCount
                </MudText>

                <MudStack Row="true" Spacing="1">
                    <AppButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.NavigateBefore"
                               Disabled="@(_request.PageNumber <= 1 || _loading)"
                               OnClick="@(async (MouseEventArgs _) => await PreviousPageAsync())">
                        Prev
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               EndIcon="@Icons.Material.Filled.NavigateNext"
                               Disabled="@(_request.PageNumber >= _totalPages || _loading)"
                               OnClick="@(async (MouseEventArgs _) => await NextPageAsync())">
                        Next
                    </AppButton>
                </MudStack>
            </MudStack>
        </Footer>
    </AppTableCard>
</AppPageShell>

@code {
    private readonly StudentListRequest _request = new();

    private readonly List<int> _pageSizeOptions = [10, 25, 50, 100];

    private List<StudentListItemResponse> _students = [];
    private List<LookupItemResponse> _academicYears = [];
    private List<LookupItemResponse> _classes = [];
    private List<LookupItemResponse> _sections = [];

    private bool _loading;
    private string? _errorMessage;
    private int _totalCount;
    private int _totalPages = 1;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", "/tenant/dashboard"),
        new("Students", null, true)
    ];

    protected override async Task OnInitializedAsync()
    {
        _request.PageNumber = _request.PageNumber <= 0 ? 1 : _request.PageNumber;
        _request.PageSize = _request.PageSize <= 0 ? 10 : _request.PageSize;

        await LoadInitialDataAsync();
    }

    private async Task LoadInitialDataAsync()
    {
        try
        {
            _loading = true;
            _errorMessage = null;

            await Session.InitializeAsync();

            if (!Session.TenantId.HasValue || !Session.BranchId.HasValue)
            {
                _errorMessage = "Tenant or Branch context is missing.";
                Snackbar.Add(_errorMessage, Severity.Error);
                return;
            }

            await LoadLookupsAsync();
            await LoadStudentsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        if (!Session.TenantId.HasValue || !Session.BranchId.HasValue)
            return;

        var tenantId = Session.TenantId.Value;
        var branchId = Session.BranchId.Value;

        var academicYearsResponse = await StudentLookupRepository.GetAcademicYearsAsync(tenantId);
        _academicYears = academicYearsResponse?.Success == true && academicYearsResponse.Data is not null
            ? academicYearsResponse.Data
            : [];

        var classesResponse = await StudentLookupRepository.GetClassesAsync(tenantId);
        _classes = classesResponse?.Success == true && classesResponse.Data is not null
            ? classesResponse.Data
            : [];

        if (_request.ClassId.HasValue)
        {
            var sectionsResponse = await StudentLookupRepository.GetSectionsByClassAsync(
                tenantId,
                branchId,
                _request.ClassId.Value);

            _sections = sectionsResponse?.Success == true && sectionsResponse.Data is not null
                ? sectionsResponse.Data
                : [];
        }
        else
        {
            _sections = [];
        }
    }

    private async Task LoadStudentsAsync()
    {
        try
        {
            _loading = true;
            _errorMessage = null;

            var response = await StudentRepository.GetPagedAsync(_request);

            if (response?.Success == true && response.Data is not null)
            {
                _students = response.Data.Items.ToList();
                _totalCount = response.Data.TotalCount;
                _totalPages = Math.Max(1, (int)Math.Ceiling((double)_totalCount / _request.PageSize));
            }
            else
            {
                _students = [];
                _totalCount = 0;
                _totalPages = 1;
                _errorMessage = response?.Message ?? "Failed to load students.";
            }
        }
        catch (Exception ex)
        {
            _students = [];
            _totalCount = 0;
            _totalPages = 1;
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchAsync()
    {
        _request.PageNumber = 1;
        await LoadStudentsAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _request.Search = null;
        _request.AcademicYearId = null;
        _request.ClassId = null;
        _request.SectionId = null;
        _request.PageNumber = 1;

        _sections = [];

        await LoadStudentsAsync();
    }

    private Task OnAcademicYearChanged(int? value)
    {
        _request.AcademicYearId = value;
        return Task.CompletedTask;
    }

    private async Task OnClassChanged(int? value)
    {
        _request.ClassId = value;
        _request.SectionId = null;
        _sections = [];

        if (!value.HasValue || !Session.TenantId.HasValue || !Session.BranchId.HasValue)
            return;

        try
        {
            var response = await StudentLookupRepository.GetSectionsByClassAsync(
                Session.TenantId.Value,
                Session.BranchId.Value,
                value.Value);

            _sections = response?.Success == true && response.Data is not null
                ? response.Data
                : [];
        }
        catch (Exception ex)
        {
            _sections = [];
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private Task OnSectionChanged(int? value)
    {
        _request.SectionId = value;
        return Task.CompletedTask;
    }

    private async Task OnPageSizeChanged(int value)
    {
        _request.PageSize = value;
        _request.PageNumber = 1;

        await LoadStudentsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_request.PageNumber <= 1)
            return;

        _request.PageNumber--;
        await LoadStudentsAsync();
    }

    private async Task NextPageAsync()
    {
        if (_request.PageNumber >= _totalPages)
            return;

        _request.PageNumber++;
        await LoadStudentsAsync();
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/tenant/students/create");
    }

    private void GoToDetails(int id)
    {
        Navigation.NavigateTo($"/tenant/students/{id}");
    }

    private static bool IsActiveStatus(string? status)
        => string.Equals(status, "active", StringComparison.OrdinalIgnoreCase);

    private static string GetStatusText(string? status)
        => string.IsNullOrWhiteSpace(status) ? "Unknown" : status;

    private static Color GetStatusColor(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "active" => Color.Success,
            "inactive" => Color.Warning,
            "left" => Color.Error,
            "suspended" => Color.Error,
            _ => Color.Default
        };
    }
}