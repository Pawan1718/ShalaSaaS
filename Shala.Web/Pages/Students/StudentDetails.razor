


@page "/tenant/students/{Id:int}"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.Students
@using Shala.Shared.Responses.Academics
@using Shala.Shared.Responses.Students
@using Shala.Web.Components.Common
@using Shala.Web.Components.Dialogs
@using Shala.Web.Components.AcademicDialogs
@using Shala.Web.Repositories.Interfaces
@using Shala.Web.Repositories.StudentRepo
@using Shala.Web.Services.State

@inject IStudentAdmissionRepository StudentAdmissionRepository
@inject IStudentGuardianRepository StudentGuardianRepository
@inject IStudentRepository StudentRepository
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ApiSession Session

<PageTitle>Student Details</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppDataState Loading="@_loading"
                  Error="@_error"
                  Empty="@(_student is null)"
                  EmptyTitle="Student not found"
                  EmptyMessage="The selected student record could not be found."
                  EmptyIcon="@Icons.Material.Filled.PersonOff">
        <EmptyActions>
            <AppButton OnClick="@((MouseEventArgs _) => GoBack())">
                Back to Students
            </AppButton>
        </EmptyActions>

        <ChildContent>
            <AppPageHeader Title="@(_student?.FullName ?? "Student Details")"
                           Subtitle="@($"Admission No: {_student?.AdmissionNo ?? "-"}")">
                <Actions>
                    <AppButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="@((MouseEventArgs _) => GoBack())">
                        Back
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@((MouseEventArgs _) => EditStudent())">
                        Edit
                    </AppButton>

                    <AppButton StartIcon="@Icons.Material.Filled.School"
                               OnClick="@((MouseEventArgs _) => AddAdmission())">
                        Add Admission
                    </AppButton>
                </Actions>
            </AppPageHeader>

            <AppToolbar>
                <Actions>
                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                               Disabled="@(!HasAdmissions)"
                               OnClick="@((MouseEventArgs _) => OpenLatestAdmissionFees())">
                        Fees
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Description"
                               Disabled="@(!HasAdmissions)"
                               OnClick="@((MouseEventArgs _) => OpenLatestAdmissionDocuments())">
                        Documents
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Warning">
                        Mark Inactive
                    </AppButton>
                </Actions>
            </AppToolbar>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <AppCard Class="h-100">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Color="Color.Primary">
                                @GetInitials(_student?.FullName)
                            </MudAvatar>

                            <MudText Typo="Typo.h5" Align="Align.Center">
                                @_student?.FullName
                            </MudText>

                            <StatusChip IsActive="@IsActiveStatus(_student?.Status)"
                                        ActiveText="@GetStatusText(_student?.Status)"
                                        InactiveText="@GetStatusText(_student?.Status)"
                                        ActiveColor="Color.Success"
                                        InactiveColor="@GetStudentStatusColor(_student?.Status)" />
                        </MudStack>

                        <MudDivider Class="my-4" />

                        <MudStack Spacing="2">
                            <DetailRow Label="Admission No" Value="@(_student?.AdmissionNo ?? "-")" />
                            <DetailRow Label="Gender" Value="@(_student?.Gender ?? "-")" />
                            <DetailRow Label="Date of Birth" Value="@FormatDate(_student?.DateOfBirth)" />
                            <DetailRow Label="Blood Group" Value="@(_student?.BloodGroup ?? "-")" />
                            <DetailRow Label="Aadhaar No" Value="@(_student?.AadhaarNo ?? "-")" />
                        </MudStack>
                    </AppCard>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudStack Spacing="3">
                        <AppCard>
                            <MudText Typo="Typo.h5" Class="mb-3">Contact Information</MudText>

                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <DetailRow Label="Mobile" Value="@(_student?.Mobile ?? "-")" />
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <DetailRow Label="Email" Value="@(_student?.Email ?? "-")" />
                                </MudItem>

                                <MudItem xs="12">
                                    <DetailRow Label="Address" Value="@(_student?.Address ?? "-")" />
                                </MudItem>
                            </MudGrid>
                        </AppCard>

                        <AppCard>
                            <MudStack Row="true"
                                      Justify="Justify.SpaceBetween"
                                      AlignItems="AlignItems.Center"
                                      Class="mb-3"
                                      Wrap="Wrap.Wrap">
                                <div>
                                    <MudText Typo="Typo.h5">Guardians</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        Guardian and parent contact details
                                    </MudText>
                                </div>

                                <MudTooltip Text="@((_student?.Guardians.Count ?? 0) >= 4 ? "Maximum 4 guardians allowed" : "Add guardian")">
                                    <span>
                                        <AppButton StartIcon="@Icons.Material.Filled.Add"
                                                   Disabled="@((_student?.Guardians.Count ?? 0) >= 4)"
                                                   OnClick="@((MouseEventArgs _) => OpenAddGuardianDialogAsync())">
                                            Add Guardian
                                        </AppButton>
                                    </span>
                                </MudTooltip>
                            </MudStack>

                            @if (_student?.Guardians is null || _student.Guardians.Count == 0)
                            {
                                <AppEmptyState Title="No guardians found"
                                               Message="Add at least one guardian for this student."
                                               Icon="@Icons.Material.Filled.SupervisorAccount" />
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    @foreach (var guardian in _student.Guardians)
                                    {
                                        <MudItem xs="12" md="6">
                                            <AppCard Class="h-100" PaddingClass="pa-3">
                                                <MudStack Row="true"
                                                          Justify="Justify.SpaceBetween"
                                                          AlignItems="AlignItems.Start">
                                                    <div>
                                                        <MudText Typo="Typo.subtitle1" Class="fw-semibold">
                                                            @guardian.Name
                                                        </MudText>

                                                        @if (guardian.IsPrimary)
                                                        {
                                                            <StatusChip IsActive="true"
                                                                        ActiveText="Primary"
                                                                        ActiveColor="Color.Success"
                                                                        Size="Size.Small" />
                                                        }

                                                        <MudStack Spacing="1" Class="mt-3">
                                                            <DetailRow Label="Relation" Value="@guardian.RelationType" />
                                                            <DetailRow Label="Mobile" Value="@guardian.Mobile" />
                                                            <DetailRow Label="Email" Value="@(string.IsNullOrWhiteSpace(guardian.Email) ? "-" : guardian.Email)" />
                                                        </MudStack>
                                                    </div>

                                                    <AppActionMenu OnEdit="@(() => OpenEditGuardianDialogAsync(guardian))"
                                                                   OnDelete="@(() => RemoveGuardianAsync(guardian))"
                                                                   DisableDelete="@(_student.Guardians.Count <= 1)" />
                                                </MudStack>
                                            </AppCard>
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                        </AppCard>
                    </MudStack>
                </MudItem>
            </MudGrid>

            <AppTableCard TItem="StudentAdmissionResponse"
                          Class="mt-4"
                          Title="Admission History"
                          Subtitle="Academic placements for this student"
                          IsLoading="false"
                          IsEmpty="@(!HasAdmissions)"
                          EmptyTitle="No admissions found"
                          EmptyMessage="Add the first academic admission for this student.">
                <Actions>
                    <AppButton StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@((MouseEventArgs _) => AddAdmission())">
                        Add Admission
                    </AppButton>
                </Actions>

                <EmptyActions>
                    <AppButton StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@((MouseEventArgs _) => AddAdmission())">
                        Add Admission
                    </AppButton>
                </EmptyActions>

                <ChildContent>
                    <MudTable T="StudentAdmissionResponse"
                              Items="@_student!.Admissions.OrderByDescending(x => x.AdmissionDate)"
                              Dense="true"
                              Hover="true"
                              Bordered="true"
                              Striped="true"
                              Breakpoint="Breakpoint.Md">
                        <HeaderContent>
                            <MudTh>Academic Year</MudTh>
                            <MudTh>Class</MudTh>
                            <MudTh>Section</MudTh>
                            <MudTh>Roll No</MudTh>
                            <MudTh>Admission Date</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh Align="Align.Right">Actions</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd DataLabel="Academic Year">@context.AcademicYear</MudTd>
                            <MudTd DataLabel="Class">@context.ClassName</MudTd>
                            <MudTd DataLabel="Section">@context.SectionName</MudTd>
                            <MudTd DataLabel="Roll No">@(string.IsNullOrWhiteSpace(context.RollNo) ? "-" : context.RollNo)</MudTd>
                            <MudTd DataLabel="Admission Date">@context.AdmissionDate.ToString("dd MMM yyyy")</MudTd>
                            <MudTd DataLabel="Status">
                                <StatusChip IsActive="@IsActiveStatus(context.Status)"
                                            ActiveText="@GetStatusText(context.Status)"
                                            InactiveText="@GetStatusText(context.Status)"
                                            ActiveColor="Color.Success"
                                            InactiveColor="@GetStudentStatusColor(context.Status)" />
                            </MudTd>
                            <MudTd DataLabel="Actions" Align="Align.Right">
                                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Wrap="Wrap.Wrap">
                                    <AppButton Variant="Variant.Outlined"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.AccountBalanceWallet"
                                               OnClick="@((MouseEventArgs _) => OpenAdmissionFees(context))">
                                        Fees
                                    </AppButton>

                                    <AppButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               OnClick="@((MouseEventArgs _) => EditAdmission(context))">
                                        Edit
                                    </AppButton>

                                    <AppButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Badge"
                                               OnClick="@((MouseEventArgs _) => OpenAssignSectionRollDialogAsync(context))">
                                        Section / Roll
                                    </AppButton>

                                    <AppButton Variant="Variant.Outlined"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="@((MouseEventArgs _) => OpenDeleteAdmissionDialogAsync(context))">
                                        Delete
                                    </AppButton>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </ChildContent>
            </AppTableCard>
        </ChildContent>
    </AppDataState>
</AppPageShell>

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private string? _error;
    private StudentDetailsResponse? _student;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private bool HasAdmissions => _student?.Admissions is not null && _student.Admissions.Count > 0;

    protected override async Task OnParametersSetAsync()
    {
        await LoadStudentAsync();
    }

    private async Task LoadStudentAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            await Session.InitializeAsync();

            if (Session.TenantId is null)
            {
                _error = "Tenant context not found.";
                return;
            }

            var response = await StudentRepository.GetByIdAsync(Id, Session.TenantId.Value);

            if (response?.Success == true && response.Data is not null)
            {
                _student = response.Data;

                _breadcrumbs =
                [
                    new("Dashboard", "/tenant/dashboard"),
                    new("Students", "/tenant/students"),
                    new(_student.FullName, null, true)
                ];
            }
            else
            {
                _student = null;
                _error = response?.Message ?? "Failed to load student.";
            }
        }
        catch (Exception ex)
        {
            _student = null;
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/tenant/students");
    }

    private void EditStudent()
    {
        Navigation.NavigateTo($"/tenant/students/{Id}/edit");
    }

    private void AddAdmission()
    {
        Navigation.NavigateTo($"/tenant/students/{Id}/admission");
    }

    private void EditAdmission(StudentAdmissionResponse admission)
    {
        Navigation.NavigateTo($"/tenant/students/{Id}/admission/{admission.Id}/edit");
    }

    private void OpenAdmissionFees(StudentAdmissionResponse admission)
    {
        Navigation.NavigateTo($"/tenant/students/{Id}/admissions/{admission.Id}/fees");
    }

    private void OpenLatestAdmissionFees()
    {
        if (!HasAdmissions)
        {
            Snackbar.Add("No admissions found for this student.", Severity.Warning);
            return;
        }

        var latestAdmission = _student!.Admissions
            .OrderByDescending(x => x.AdmissionDate)
            .First();

        Navigation.NavigateTo($"/tenant/students/{Id}/admissions/{latestAdmission.Id}/fees");
    }

    private async Task OpenDeleteAdmissionDialogAsync(StudentAdmissionResponse admission)
    {
        if (_student is null)
            return;

        try
        {
            await Session.InitializeAsync();

            if (Session.TenantId is null || Session.BranchId is null)
            {
                Snackbar.Add("Tenant or branch context not found.", Severity.Error);
                return;
            }

            var parameters = new DialogParameters
            {
                ["Title"] = "Delete Admission",
                ["Message"] = $"Are you sure you want to delete admission '{admission.AdmissionNo}'?",
                ["ConfirmText"] = "Delete",
                ["ConfirmColor"] = Color.Error
            };

            var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm", parameters);
            var result = await dialog.Result;

            if (result == null || result.Canceled)
                return;

            var response = await StudentAdmissionRepository.DeleteAsync(
                admission.Id,
                Session.TenantId.Value,
                Session.BranchId.Value);

            if (response?.Success == true)
            {
                Snackbar.Add(response.Message ?? "Admission deleted successfully.", Severity.Success);
                await LoadStudentAsync();
            }
            else
            {
                Snackbar.Add(response?.Message ?? "Failed to delete admission.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenAssignSectionRollDialogAsync(StudentAdmissionResponse admission)
    {
        var parameters = new DialogParameters
        {
            ["StudentAdmissionId"] = admission.Id
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraLarge
        };

        var dialog = await DialogService.ShowAsync<AssignSectionRollDialog>(
            "Assign Section & Roll Number",
            parameters,
            options);

        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
            await LoadStudentAsync();
    }

    private async Task OpenAddGuardianDialogAsync()
    {
        if (_student is null || _student.Guardians.Count >= 4)
            return;

        var parameters = new DialogParameters
        {
            ["Model"] = new CreateGuardianRequest
            {
                Name = string.Empty,
                RelationType = 3,
                Mobile = string.Empty,
                Email = null,
                Occupation = null,
                Address = null,
                IsPrimary = _student.Guardians.Count == 0
            },
            ["IsEdit"] = false
        };

        var dialog = await DialogService.ShowAsync<GuardianDialog>("Add Guardian", parameters);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is null)
            return;

        var request = (CreateGuardianRequest)result.Data;
        var response = await StudentGuardianRepository.AddAsync(_student.Id, request);

        if (response?.Success == true)
        {
            Snackbar.Add("Guardian added successfully.", Severity.Success);
            await LoadStudentAsync();
        }
        else
        {
            Snackbar.Add(response?.Message ?? "Failed to add guardian.", Severity.Error);
        }
    }

    private async Task OpenEditGuardianDialogAsync(GuardianResponse guardian)
    {
        if (_student is null)
            return;

        var parameters = new DialogParameters
        {
            ["Model"] = new CreateGuardianRequest
            {
                Name = guardian.Name,
                RelationType = MapRelationTypeToInt(guardian.RelationType),
                Mobile = guardian.Mobile,
                Email = guardian.Email,
                IsPrimary = guardian.IsPrimary
            },
            ["IsEdit"] = true
        };

        var dialog = await DialogService.ShowAsync<GuardianDialog>("Edit Guardian", parameters);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is null)
            return;

        var request = (CreateGuardianRequest)result.Data;
        var response = await StudentGuardianRepository.UpdateAsync(_student.Id, guardian.Id, request);

        if (response?.Success == true)
        {
            Snackbar.Add("Guardian updated successfully.", Severity.Success);
            await LoadStudentAsync();
        }
        else
        {
            Snackbar.Add(response?.Message ?? "Failed to update guardian.", Severity.Error);
        }
    }

    private void OpenAdmissionDocuments(StudentAdmissionResponse admission)
    {
        Navigation.NavigateTo($"/tenant/students/{Id}/admissions/{admission.Id}/documents");
    }

    private void OpenLatestAdmissionDocuments()
    {
        if (!HasAdmissions)
        {
            Snackbar.Add("No admissions found for this student.", Severity.Warning);
            return;
        }

        var latestAdmission = _student!.Admissions
            .OrderByDescending(x => x.AdmissionDate)
            .First();

        Navigation.NavigateTo($"/tenant/students/{Id}/admissions/{latestAdmission.Id}/documents");
    }

    private async Task RemoveGuardianAsync(GuardianResponse guardian)
    {
        if (_student is null || _student.Guardians.Count <= 1)
            return;

        var parameters = new DialogParameters
        {
            ["Title"] = "Remove Guardian",
            ["Message"] = $"Are you sure you want to remove {guardian.Name}?",
            ["ConfirmText"] = "Remove",
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm", parameters);
        var result = await dialog.Result;

        if (result == null || result.Canceled)
            return;

        var response = await StudentGuardianRepository.RemoveAsync(_student.Id, guardian.Id, _student.TenantId);

        if (response?.Success == true)
        {
            Snackbar.Add("Guardian removed successfully.", Severity.Success);
            await LoadStudentAsync();
        }
        else
        {
            Snackbar.Add(response?.Message ?? "Failed to remove guardian.", Severity.Error);
        }
    }

    private static string GetInitials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "S";

        var parts = fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(x => char.ToUpperInvariant(x[0]));

        return string.Concat(parts);
    }

    private static string FormatDate(DateTime? value)
    {
        if (value is null || value.Value == default)
            return "-";

        return value.Value.ToString("dd MMM yyyy");
    }

    private static bool IsActiveStatus(string? status)
        => string.Equals(status, "active", StringComparison.OrdinalIgnoreCase);

    private static string GetStatusText(string? status)
        => string.IsNullOrWhiteSpace(status) ? "Unknown" : status;

    private static Color GetStudentStatusColor(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "active" => Color.Success,
            "inactive" => Color.Warning,
            "left" => Color.Error,
            "suspended" => Color.Error,
            "alumni" => Color.Info,
            _ => Color.Default
        };
    }

    private static int MapRelationTypeToInt(string relationType)
    {
        return relationType switch
        {
            "Father" => 1,
            "Mother" => 2,
            "Guardian" => 3,
            _ => 4
        };
    }
}