@page "/tenant/students/{StudentId:int}/documents"

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.StudentDocument
@using Shala.Shared.Responses.StudentDocument
@using Shala.Web.Components.StudentDocuments
@using Shala.Web.Repositories.StudentDocuments
@layout Components.Layouts.TenantMainLayout

@inject IStudentDocumentWebRepository Repo
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Student Documents</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
    <MudStack Spacing="3">

        <MudPaper Class="pa-5 rounded-xl">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <div>
                    <MudText Typo="Typo.h4" Class="fw-bold">Student Documents</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                        Upload, analyze, verify, and manage documents for student ID: @StudentId
                    </MudText>
                </div>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="GoBack">
                        Back
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadAsync"
                               Disabled="_loading">
                        Reload
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               OnClick="OpenUploadDialogAsync"
                               Disabled="_loading">
                        Upload Document
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">
                @_error
            </MudAlert>
        }

        <MudPaper Class="pa-4 rounded-xl">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <MudTextField T="string"
                              Placeholder="Search by title, type, status..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Style="max-width: 320px;"
                              @bind-Value="_searchText"
                              Immediate="true" />

                <MudSwitch T="bool"
                           @bind-Value="_showOnlyActive"
                           Color="Color.Primary"
                           Label="Show only active" />
            </MudStack>
        </MudPaper>

        <MudPaper Class="rounded-xl overflow-hidden">
            @if (_loading)
            {
                <MudStack Class="pa-6" AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">Loading student documents...</MudText>
                </MudStack>
            }
            else if (!FilteredItems.Any())
            {
                <MudStack Class="pa-6" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6">No documents found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Upload a document to begin processing.</MudText>
                </MudStack>
            }
            else
            {
                <MudTable Items="FilteredItems" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Title</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Verified</MudTh>
                        <MudTh>Active</MudTh>
                        <MudTh>File</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh style="width:300px;">Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                                @if (!string.IsNullOrWhiteSpace(context.Remarks))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Remarks</MudText>
                                }
                            </MudStack>
                        </MudTd>

                        <MudTd>@context.DocumentType</MudTd>

                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                                @context.Status
                            </MudChip>
                        </MudTd>

                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsVerified ? Color.Success : Color.Default)">
                                @(context.IsVerified ? "Verified" : "Pending")
                            </MudChip>
                        </MudTd>

                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                                @(context.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </MudTd>

                        <MudTd>
                            <MudText Typo="Typo.caption">@context.FileName</MudText>
                        </MudTd>

                        <MudTd>
                            <MudText Typo="Typo.caption">@context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</MudText>
                        </MudTd>

                        <MudTd>
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Psychology"
                                           OnClick="@(() => AnalyzeAsync(context))">
                                    Analyze
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Verified"
                                           OnClick="@(() => VerifyAsync(context, !context.IsVerified))">
                                    @(context.IsVerified ? "Unverify" : "Verify")
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="@(context.IsActive ? Color.Warning : Color.Info)"
                                           StartIcon="@(context.IsActive ? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                           OnClick="@(() => ToggleStatusAsync(context))">
                                    @(context.IsActive ? "Inactive" : "Activate")
                                </MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        @if (_lastAnalysis is not null)
        {
            <MudPaper Class="pa-4 rounded-xl">
                <MudText Typo="Typo.h6" Class="mb-2">Last Analysis Result</MudText>

                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Detected Type</MudText>
                        <MudText Typo="Typo.body1">@(_lastAnalysis.DetectedDocumentType ?? "-")</MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">OCR Confidence</MudText>
                        <MudText Typo="Typo.body1">@(_lastAnalysis.OcrConfidence?.ToString() ?? "-")</MudText>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">AI Confidence</MudText>
                        <MudText Typo="Typo.body1">@(_lastAnalysis.AiConfidence?.ToString() ?? "-")</MudText>
                    </MudItem>

                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Analysis Status</MudText>
                        <MudText Typo="Typo.body1">@_lastAnalysis.AnalysisStatus</MudText>
                    </MudItem>

                    @if (!string.IsNullOrWhiteSpace(_lastAnalysis.ExtractedText))
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Extracted Text</MudText>
                            <MudPaper Class="pa-3 mt-1" Outlined="true">
                                <MudText Typo="Typo.body2">@_lastAnalysis.ExtractedText</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    [Parameter] public int StudentId { get; set; }

    private List<StudentDocumentResponse> _items = new();
    private List<DocumentModelResponse> _activeModels = new();
    private StudentDocumentAnalysisResponse? _lastAnalysis;

    private bool _loading;
    private string? _error;
    private string _searchText = string.Empty;
    private bool _showOnlyActive = true;

    private IEnumerable<StudentDocumentResponse> FilteredItems =>
        _items
            .Where(x => !_showOnlyActive || x.IsActive)
            .Where(x =>
                string.IsNullOrWhiteSpace(_searchText) ||
                (x.Title?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.DocumentType?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.Status?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (x.FileName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderByDescending(x => x.CreatedAt);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_loading)
            return;

        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var docsTask = Repo.GetByStudentIdAsync(StudentId);
            var modelsTask = Repo.GetActiveModelsAsync();

            await Task.WhenAll(docsTask, modelsTask);

            _items = docsTask.Result ?? new();
            _activeModels = modelsTask.Result ?? new();
        }
        catch (Exception ex)
        {
            _items = new();
            _activeModels = new();
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenUploadDialogAsync()
    {
        if (_loading)
            return;

        try
        {
            if (!_activeModels.Any())
            {
                _activeModels = await Repo.GetActiveModelsAsync();
            }

            if (!_activeModels.Any())
            {
                Snackbar.Add("No active document models found. Please configure document models first.", Severity.Warning);
                return;
            }

            var parameters = new DialogParameters
            {
                [nameof(StudentDocumentUploadDialog.StudentId)] = StudentId,
                [nameof(StudentDocumentUploadDialog.DocumentModels)] = _activeModels
            };

            var options = new DialogOptions
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true
            };

            var dialog = await DialogService.ShowAsync<StudentDocumentUploadDialog>(
                "Upload Student Document",
                parameters,
                options);

            var result = await dialog.Result;

            if (!result.Canceled)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task AnalyzeAsync(StudentDocumentResponse item)
    {
        try
        {
            _lastAnalysis = await Repo.AnalyzeAsync(new AnalyzeStudentDocumentRequest
            {
                StudentDocumentId = item.Id,
                ForceReAnalyze = false
            });

            Snackbar.Add("Document analysis completed.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task VerifyAsync(StudentDocumentResponse item, bool verify)
    {
        try
        {
            await Repo.VerifyAsync(new VerifyStudentDocumentRequest
            {
                StudentDocumentId = item.Id,
                IsVerified = verify,
                Remarks = verify ? "Verified from web UI." : "Marked for review from web UI."
            });

            Snackbar.Add(verify ? "Document verified successfully." : "Document moved to review state.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ToggleStatusAsync(StudentDocumentResponse item)
    {
        try
        {
            await Repo.ToggleStatusAsync(new ToggleStudentDocumentStatusRequest
            {
                StudentDocumentId = item.Id,
                IsActive = !item.IsActive,
                Remarks = item.IsActive ? "Marked inactive from web UI." : "Re-activated from web UI."
            });

            Snackbar.Add(item.IsActive ? "Document marked inactive." : "Document activated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/tenant/students");
    }

    private static Color GetStatusColor(string? status)
    {
        return status switch
        {
            "Uploaded" => Color.Info,
            "Analyzed" => Color.Primary,
            "Verified" => Color.Success,
            "NeedsReview" => Color.Warning,
            "Inactive" => Color.Default,
            _ => Color.Default
        };
    }
}