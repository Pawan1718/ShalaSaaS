@page "/platform/dashboard"
@layout Shala.Web.Components.Layouts.PlatformMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Responses.Platform
@using Shala.Web.Repositories.PlatformRepo
@using Shala.Web.Services.State

@inject IPlatformDashboardRepository DashboardRepository
@inject ISnackbar Snackbar
@inject ApiSession ApiSession

<PageTitle>Platform Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="dashboard-page">

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="dashboard-header">
        <div>
            <MudText Typo="Typo.h3" Class="fw-700">Platform Dashboard</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Live tenant analytics, subscriptions, growth insights and latest onboarding activity.
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadDashboardClickAsync"
                   Disabled="_isLoading">
            Refresh
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudGrid Spacing="3">
            @for (int i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" md="4" lg="2">
                    <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                        <MudSkeleton Height="18px" Width="60%" />
                        <MudSkeleton Height="34px" Width="45%" Class="mt-4" />
                    </MudPaper>
                </MudItem>
            }

            <MudItem xs="12" lg="8">
                <MudPaper Class="modern-card pa-4" Elevation="1">
                    <MudSkeleton Height="24px" Width="35%" />
                    <MudSkeleton Height="220px" Width="100%" Class="mt-4" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="modern-card pa-4" Elevation="1">
                    <MudSkeleton Height="24px" Width="50%" />
                    <MudSkeleton Height="220px" Width="100%" Class="mt-4" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="modern-card pa-4" Elevation="1">
                    <MudSkeleton Height="24px" Width="25%" />
                    @for (int i = 0; i < 6; i++)
                    {
                        <MudSkeleton Height="20px" Width="100%" Class="mt-3" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="false">
            @_errorMessage
        </MudAlert>
    }
    else if (_data is null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
            No dashboard data found.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Total Tenants</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.TotalTenants</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Primary" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.Business" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Active</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.ActiveTenants</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Success" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Inactive</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.InactiveTenants</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Error" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">New This Month</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.NewTenantsThisMonth</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Info" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Premium Plans</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.TotalPremiumPlans</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Warning" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.Star" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="modern-card stat-card pa-4" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Last 30 Days</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-2">@_data.NewTenantsLast30Days</MudText>
                        </div>
                        <MudAvatar Size="Size.Large" Color="Color.Secondary" Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="8">
                <MudPaper Class="modern-card pa-5" Elevation="1">
                    <MudText Typo="Typo.h5" Class="fw-700 mb-1">Performance Snapshot</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Quick summary of activation, subscription mix and category performance.
                    </MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudPaper Class="mini-insight pa-4" Outlined="true">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.Assessment" />
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Activation Rate</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700">@ActivationRateText</MudText>
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="mini-insight pa-4" Outlined="true">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudAvatar Color="Color.Info" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.AutoGraph" />
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Most Used Plan</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700">@TopPlanText</MudText>
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="mini-insight pa-4" Outlined="true">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudAvatar Color="Color.Success" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.Groups" />
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Top Category</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700">@TopCategoryText</MudText>
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-4" />

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="plan-tile pa-4" Outlined="true">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Free</MudText>
                                <MudText Typo="Typo.h5" Class="fw-700">@_data.TotalFreePlans</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="plan-tile pa-4" Outlined="true">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Basic</MudText>
                                <MudText Typo="Typo.h5" Class="fw-700">@_data.TotalBasicPlans</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="plan-tile pa-4" Outlined="true">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Standard</MudText>
                                <MudText Typo="Typo.h5" Class="fw-700">@_data.TotalStandardPlans</MudText>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="plan-tile pa-4" Outlined="true">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Enterprise</MudText>
                                <MudText Typo="Typo.h5" Class="fw-700">@_data.TotalEnterprisePlans</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Class="modern-card pa-5" Elevation="1">
                    <MudText Typo="Typo.h5" Class="fw-700 mb-1">Recent Trend</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Latest onboarding and overall platform momentum.
                    </MudText>

                    <MudStack Spacing="3">
                        <MudPaper Class="mini-insight pa-4" Outlined="true">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">New Tenants in Last 30 Days</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-1">@_data.NewTenantsLast30Days</MudText>
                        </MudPaper>

                        <MudPaper Class="mini-insight pa-4" Outlined="true">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Categories Tracked</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-1">@(_data.CategoryBreakdown?.Count ?? 0)</MudText>
                        </MudPaper>

                        <MudPaper Class="mini-insight pa-4" Outlined="true">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Recent Tenant Records</MudText>
                            <MudText Typo="Typo.h4" Class="fw-700 mt-1">@(_data.RecentTenants?.Count ?? 0)</MudText>
                        </MudPaper>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="modern-card pa-5" Elevation="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4 table-header-wrap">
                        <div>
                            <MudText Typo="Typo.h5" Class="fw-700">Recent Tenants</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Latest schools added on the platform.
                            </MudText>
                        </div>

                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                            @(_data.RecentTenants?.Count ?? 0) record(s)
                        </MudChip>
                    </MudStack>

                    @if (_data.RecentTenants is null || _data.RecentTenants.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            No recent tenant records available.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_data.RecentTenants"
                                  Hover="true"
                                  Dense="false"
                                  Striped="true"
                                  Breakpoint="Breakpoint.Md"
                                  Elevation="0">

                            <HeaderContent>
                                <MudTh>Name</MudTh>
                                <MudTh>Category</MudTh>
                                <MudTh>Email</MudTh>
                                <MudTh>Plan</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Created</MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd DataLabel="Name">
                                    <MudText Typo="Typo.body1" Class="fw-600">@context.Name</MudText>
                                </MudTd>

                                <MudTd DataLabel="Category">
                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Info">
                                        @context.BusinessCategory
                                    </MudChip>
                                </MudTd>

                                <MudTd DataLabel="Email">@context.Email</MudTd>

                                <MudTd DataLabel="Plan">
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                        @context.SubscriptionPlan
                                    </MudChip>
                                </MudTd>

                                <MudTd DataLabel="Status">
                                    <MudChip T="string"
                                             Variant="Variant.Filled"
                                             Color="@(context.IsActive ? Color.Success : Color.Error)"
                                             Size="Size.Small">
                                        @(context.IsActive ? "Active" : "Inactive")
                                    </MudChip>
                                </MudTd>

                                <MudTd DataLabel="Created">
                                    @context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>

        </MudGrid>
    }
</MudContainer>

<style>
    .dashboard-page {
        padding: 24px;
        background: #f8fafc;
        min-height: 100%;
    }

    .dashboard-header {
        margin-bottom: 24px;
        gap: 16px;
    }

    .modern-card {
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
        border: 1px solid rgba(148, 163, 184, 0.12);
    }

    .stat-card {
        min-height: 132px;
    }

    .mini-insight {
        border-radius: 16px;
        background: #fcfcff;
    }

    .plan-tile {
        border-radius: 16px;
        text-align: left;
        background: #fcfcff;
    }

    .fw-700 {
        font-weight: 700;
    }

    .fw-600 {
        font-weight: 600;
    }

    .table-header-wrap {
        gap: 12px;
    }

    @@media (max-width: 960px) {
        .dashboard-header,
        .table-header-wrap {
            flex-direction: column;
            align-items: stretch !important;
        }
    }
</style>

@code {
    private PlatformDashboardResponse? _data;
    private bool _isLoading = true;
    private string? _errorMessage;

    private string ActivationRateText =>
        _data is null || _data.TotalTenants == 0
            ? "0%"
            : $"{Math.Round((_data.ActiveTenants * 100.0) / _data.TotalTenants, 1)}%";

    private string TopPlanText =>
        _data is null || _data.SubscriptionBreakdown is null || _data.SubscriptionBreakdown.Count == 0
            ? "-"
            : _data.SubscriptionBreakdown.OrderByDescending(x => x.Value).First().Label;

    private string TopCategoryText =>
        _data is null || _data.CategoryBreakdown is null || _data.CategoryBreakdown.Count == 0
            ? "-"
            : _data.CategoryBreakdown.OrderByDescending(x => x.Value).First().Label;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardClickAsync(MouseEventArgs _)
    {
        await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _data = null;

        await InvokeAsync(StateHasChanged);

        try
        {
            await ApiSession.InitializeAsync();

            if (!ApiSession.IsAuthenticated)
            {
                _errorMessage = "Session expired or authentication token is not available.";
                Snackbar.Add(_errorMessage, Severity.Error);
                return;
            }

            var response = await DashboardRepository.GetSummaryAsync();

            if (response.IsSuccess && response.ServerResponse is not null)
            {
                _data = response.ServerResponse;
            }
            else
            {
                var body = await response.GetBodyPartAsync();

                _errorMessage = !string.IsNullOrWhiteSpace(response.Message)
                    ? $"{response.Message} | Raw: {body}"
                    : $"Unable to load dashboard data from server. | Raw: {body}";

                Snackbar.Add(_errorMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Dashboard load failed."
                : ex.Message;

            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}