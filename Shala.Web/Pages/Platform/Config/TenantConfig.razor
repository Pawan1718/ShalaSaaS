@page "/platform/configuration/tenant"
@layout Shala.Web.Components.Layouts.PlatformMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Web.Components.Common

<PageTitle>Tenant Configuration</PageTitle>

<AppPageHeader Title="Tenant Configuration"
               Subtitle="Manage tenant setup" />

<AppCard>

    <MudTabs Elevation="0" Rounded="true" PanelClass="pa-4">

        <!-- ONLY ONE TAB -->
        <MudTabPanel Text="Branches" Icon="@Icons.Material.Filled.AccountTree">

            <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-8">

                <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                         Size="Size.Large"
                         Color="Color.Primary" />

                <MudText Typo="Typo.h6">
                    Manage Branches
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Add, edit and manage all branches from the branch setup page.
                </MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           Href="/platform/configuration/branches">
                    Open Branch Setup
                </MudButton>

            </MudStack>

        </MudTabPanel>

    </MudTabs>

</AppCard>