@page "/tenant/settings"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject NavigationManager Nav

<PageTitle>Settings & Configuration</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="settings-page">
    <MudStack Spacing="4">

        <!-- Page Header -->
        <MudPaper Class="settings-header" Elevation="0">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4" Class="fw-700">Settings & Configuration</MudText>
                <MudText Typo="Typo.body1" Class="text-muted">
                    Manage school setup, academic structure, admissions, users, fees, documents and future operational controls from one place.
                </MudText>
            </MudStack>
        </MudPaper>

        @SectionBlock(
            "School & Branding",
            "Manage school identity, document branding and reusable document configurations.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    @PlaceholderCard(
                        "School Profile",
                        "Manage school name, logo, contact details and institutional profile.",
                        Icons.Material.Filled.Business,
                        "Coming Soon")
                </MudItem>

                <MudItem xs="12" md="4">
                    @ActionCard(
                        "Branch Document Profile",
                        "Configure receipt branding, print settings and footer visibility.",
                        Icons.Material.Filled.ReceiptLong,
                        "Open",
                        "/settings/branch-document-profile")
                </MudItem>

                <MudItem xs="12" md="4">
                    @ActionCard(
                        "Document Models",
                        "Manage reusable document models and tenant-level templates.",
                        Icons.Material.Filled.Article,
                        "Open",
                        "/tenant/settings/document-models")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Academic Setup",
            "Configure academic years, classes, sections, roll settings and section assignment.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6" lg="3">
                    @ActionCard("Academic Years", "Manage academic sessions and active year.", Icons.Material.Filled.CalendarMonth, "Open", "/students/setup/academic-years")
                </MudItem>

                <MudItem xs="12" md="6" lg="3">
                    @ActionCard("Classes", "Define class structure and order.", Icons.Material.Filled.Class, "Open", "/students/setup/classes")
                </MudItem>

                <MudItem xs="12" md="6" lg="3">
                    @ActionCard("Sections", "Manage class-wise sections.", Icons.Material.Filled.ViewWeek, "Open", "/students/setup/sections")
                </MudItem>

                <MudItem xs="12" md="6" lg="3">
                    @ActionCard("Roll Number Settings", "Configure roll number rules.", Icons.Material.Filled.FormatListNumbered, "Open", "/students/setup/roll-number-settings")
                </MudItem>

                <MudItem xs="12">
                    @ActionCard("Section / Roll Assignment", "Assign students to sections and manage roll workflows.", Icons.Material.Filled.SwapVert, "Open", "/tenant/academics/section-roll-assignment")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Admissions & Registration",
            "Configure registration settings and future admission workflow controls.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @ActionCard("Registration Configuration", "Manage registration fees, receipt setup and prospectus rules.", Icons.Material.Filled.HowToReg, "Open", "/settings/registration-configuration")
                </MudItem>

                <MudItem xs="12" md="6">
                    @PlaceholderCard("Admission Workflow", "Reserved for approval rules, stage setup and admission checklist.", Icons.Material.Filled.FactCheck, "Coming Soon")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Users & Access",
            "Manage tenant users and future permission controls.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @ActionCard("Users", "Manage staff users and operational access.", Icons.Material.Filled.Group, "Manage", "/tenant/users")
                </MudItem>

                <MudItem xs="12" md="6">
                    @PlaceholderCard("Permissions", "Reserved for role permissions and controlled access.", Icons.Material.Filled.AdminPanelSettings, "Coming Soon")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Finance",
            "Manage fee setup and future finance controls.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @ActionCard("Fee Heads", "Create and manage fee heads.", Icons.Material.Filled.ReceiptLong, "Open", "/tenant/settings/fees/heads")
                </MudItem>

                <MudItem xs="12" md="6">
                    @ActionCard("Fee Structures", "Manage fee structures and setup.", Icons.Material.Filled.AccountBalanceWallet, "Open", "/tenant/settings/fees/structures")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Documents & Supplies",
            "Manage document setup and student supply workflows.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @ActionCard("Document Models", "Open and manage document models.", Icons.Material.Filled.Description, "Open", "/tenant/settings/document-models")
                </MudItem>

                <MudItem xs="12" md="6">
                    @ActionCard("Student Supplies", "Manage issue flow and supply operations.", Icons.Material.Filled.Inventory2, "Open", "/tenant/supplies/issues")
                </MudItem>
            </MudGrid>
        )

        @SectionBlock(
            "Reports & Analytics",
            "Reserved for future reporting and insights.",
            @<MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    @PlaceholderCard("Reports", "Reserved for operational and finance reports.", Icons.Material.Filled.Assessment, "Coming Soon")
                </MudItem>

                <MudItem xs="12" md="6">
                    @PlaceholderCard("Analytics", "Reserved for trends, KPIs and dashboards.", Icons.Material.Filled.Insights, "Coming Soon")
                </MudItem>
            </MudGrid>
        )

    </MudStack>
</MudContainer>

<style>
    .settings-page {
        padding: 24px;
    }

    .settings-header {
        padding: 24px;
        border-radius: 16px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .settings-section {
        padding: 22px;
        border-radius: 16px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
    }

    .settings-card {
        height: 100%;
        padding: 20px;
        border-radius: 14px;
        background: #ffffff;
        border: 1px solid #edf0f3;
    }

    .settings-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
    }

    .fw-700 {
        font-weight: 700;
    }

    .text-muted {
        color: #64748b;
    }

    @@media (max-width: 960px) {
        .settings-page {
            padding: 16px;
        }

        .settings-header,
        .settings-section {
            padding: 16px;
        }
    }
</style>

@code {
    private void GoTo(string url)
    {
        Nav.NavigateTo(url);
    }

    private RenderFragment SectionBlock(string title, string description, RenderFragment content) => @<MudPaper Class="settings-section" Elevation="0">
        <MudStack Spacing="3">
            <div>
                <MudText Typo="Typo.h6" Class="fw-700">@title</MudText>
                <MudText Typo="Typo.body2" Class="text-muted">@description</MudText>
            </div>

            @content
        </MudStack>
    </MudPaper>;

    private RenderFragment ActionCard(
        string title,
        string description,
        string icon,
        string buttonText,
        string url) => @<MudPaper Class="settings-card" Elevation="0">
        <MudStack Spacing="2" Class="h-100">
            <div class="settings-card-icon">
                <MudIcon Icon="@icon" />
            </div>

            <MudText Typo="Typo.subtitle1" Class="fw-700">@title</MudText>

            <MudText Typo="Typo.body2" Class="text-muted">
                @description
            </MudText>

            <MudSpacer />

            <MudButton Variant="Variant.Text"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="@(() => GoTo(url))">
                @buttonText
            </MudButton>
        </MudStack>
    </MudPaper>;

    private RenderFragment PlaceholderCard(
        string title,
        string description,
        string icon,
        string buttonText) => @<MudPaper Class="settings-card" Elevation="0">
        <MudStack Spacing="2" Class="h-100">
            <div class="settings-card-icon">
                <MudIcon Icon="@icon" />
            </div>

            <MudText Typo="Typo.subtitle1" Class="fw-700">@title</MudText>

            <MudText Typo="Typo.body2" Class="text-muted">
                @description
            </MudText>

            <MudSpacer />

            <MudButton Variant="Variant.Text"
                       Disabled="true"
                       StartIcon="@Icons.Material.Filled.Lock">
                @buttonText
            </MudButton>
        </MudStack>
    </MudPaper>;
}