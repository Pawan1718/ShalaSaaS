@page "/tenant/users"

@using MudBlazor
@using Shala.Shared.Requests.Tenant
@using Shala.Shared.Responses.Platform
@using Shala.Web.Components.Dialogs
@using Shala.Web.Components.Common
@using Shala.Web.Repositories.TenantRepo

@layout Shala.Web.Components.Layouts.TenantMainLayout
@inject ITenantUserRepository UserRepo
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudStack Spacing="3">

        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.h5">Users</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Manage staff users, roles and branch access.
                    </MudText>
                </div>

                <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="_isLoading"
                           OnClick="OpenCreateDialog">
                    Create User
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-3" Elevation="0" Outlined="true">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudTextField T="string"
                              @bind-Value="_search"
                              Placeholder="Search name, email, role, branch..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Class="flex-grow-1" />

                <MudSelect T="string"
                           @bind-Value="_statusFilter"
                           Label="Status"
                           Variant="Variant.Outlined"
                           Style="width:180px">
                    <MudSelectItem T="string" Value="@("all")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("active")">Active</MudSelectItem>
                    <MudSelectItem T="string" Value="@("inactive")">Inactive</MudSelectItem>
                </MudSelect>

                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="_isLoading"
                           OnClick="LoadUsersAsync">
                    Refresh
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Outlined="true">
            <MudTable Items="FilteredUsers"
                      Hover="true"
                      Dense="false"
                      Loading="_isLoading"
                      Breakpoint="Breakpoint.Sm"
                      Class="rounded-lg">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Default Branch</MudTh>
                    <MudTh>Allowed Branches</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="width:140px">Actions</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2"><b>@context.FullName</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @(string.IsNullOrWhiteSpace(context.MobileNumber) ? "—" : context.MobileNumber)
                            </MudText>
                        </MudStack>
                    </MudTd>

                    <MudTd DataLabel="Email">@context.Email</MudTd>

                    <MudTd DataLabel="Role">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetRoleColor(context)"
                                 Variant="Variant.Outlined">
                            @GetPrimaryRole(context)
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Default Branch">
                        @(string.IsNullOrWhiteSpace(context.DefaultBranchName) ? "—" : context.DefaultBranchName)
                    </MudTd>

                    <MudTd DataLabel="Allowed Branches">
                        @if (context.AllowedBranchNames?.Any() == true)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var branchName in context.AllowedBranchNames.Take(3))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                        @branchName
                                    </MudChip>
                                }

                                @if (context.AllowedBranchNames.Count > 3)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">
                                        +@(context.AllowedBranchNames.Count - 3)
                                    </MudChip>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                        }
                    </MudTd>

                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsActive ? Color.Success : Color.Error)"
                                 Variant="Variant.Filled">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>

                    <MudTd DataLabel="Actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       Disabled="_isLoading"
                                       OnClick="@(() => OpenEditDialog(context))" />

                        <MudIconButton Icon="@(context.IsActive ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                                       Color="@(context.IsActive ? Color.Warning : Color.Success)"
                                       Size="Size.Small"
                                       Disabled="_isLoading"
                                       OnClick="@(() => ToggleStatus(context))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       Disabled="_isLoading"
                                       OnClick="@(() => DeleteUser(context))" />
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                        <MudIcon Icon="@Icons.Material.Filled.GroupOff" Size="Size.Large" />
                        <MudText>No users found.</MudText>
                    </MudStack>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>

    </MudStack>
</MudContainer>

@code {
    private List<UserListItemResponse> _users = new();
    private bool _isLoading;
    private string _search = string.Empty;
    private string _statusFilter = "all";

    private IEnumerable<UserListItemResponse> FilteredUsers
    {
        get
        {
            var query = _users.AsEnumerable();

            if (_statusFilter == "active")
                query = query.Where(x => x.IsActive);

            if (_statusFilter == "inactive")
                query = query.Where(x => !x.IsActive);

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim().ToLower();

                query = query.Where(x =>
                    (x.FullName ?? string.Empty).ToLower().Contains(s) ||
                    (x.Email ?? string.Empty).ToLower().Contains(s) ||
                    (x.MobileNumber ?? string.Empty).ToLower().Contains(s) ||
                    GetPrimaryRole(x).ToLower().Contains(s) ||
                    (x.DefaultBranchName ?? string.Empty).ToLower().Contains(s) ||
                    (x.AllowedBranchNames != null &&
                     x.AllowedBranchNames.Any(b => (b ?? string.Empty).ToLower().Contains(s))));
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            _isLoading = true;

            var res = await UserRepo.GetUsersAsync();

            if (res.IsSuccess)
            {
                _users = res.ServerResponse ?? new List<UserListItemResponse>();
            }
            else
            {
                Snackbar.Add(res.Message ?? "Failed to load users.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateTenantUserDialog>(
            "Create User",
            new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true
            });

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadUsersAsync();
    }

    private async Task OpenEditDialog(UserListItemResponse user)
    {
        var parameters = new DialogParameters
        {
            ["User"] = user
        };

        var dialog = await DialogService.ShowAsync<EditTenantUserDialog>(
            "Edit User",
            parameters,
            new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseButton = true
            });

        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadUsersAsync();
    }

    private async Task ToggleStatus(UserListItemResponse user)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Change Status",
            ["Message"] = user.IsActive
                ? $"Deactivate {user.FullName}?"
                : $"Activate {user.FullName}?",
            ["ConfirmText"] = user.IsActive ? "Deactivate" : "Activate",
            ["ConfirmColor"] = user.IsActive ? Color.Warning : Color.Success
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Confirm",
            parameters,
            new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraSmall,
                FullWidth = true,
                CloseButton = true
            });

        var result = await dialog.Result;

        if (result.Canceled)
            return;

        var request = new UpdateTenantUserStatusRequest
        {
            IsActive = !user.IsActive
        };

        var res = await UserRepo.UpdateUserStatusAsync(user.Id, request);

        if (res.IsSuccess)
        {
            Snackbar.Add(
                request.IsActive ? "User activated." : "User deactivated.",
                Severity.Success);

            await LoadUsersAsync();
            return;
        }

        Snackbar.Add(res.Message ?? "Failed to update user status.", Severity.Error);
    }

    private async Task DeleteUser(UserListItemResponse user)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = "Delete user",
            ["Message"] = $"Delete {user.FullName}? This will deactivate the user.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Confirm",
            parameters,
            new DialogOptions
            {
                MaxWidth = MaxWidth.ExtraSmall,
                FullWidth = true,
                CloseButton = true
            });

        var result = await dialog.Result;

        if (result.Canceled)
            return;

        var res = await UserRepo.DeleteUserAsync(user.Id);

        if (res.IsSuccess)
        {
            Snackbar.Add("User deleted.", Severity.Success);
            await LoadUsersAsync();
            return;
        }

        Snackbar.Add(res.Message ?? "Failed to delete user.", Severity.Error);
    }

    private static string GetPrimaryRole(UserListItemResponse user)
    {
        return user.Roles?.FirstOrDefault() ?? "User";
    }

    private static Color GetRoleColor(UserListItemResponse user)
    {
        return GetPrimaryRole(user) switch
        {
            "SchoolAdmin" => Color.Error,
            "BranchAdmin" => Color.Warning,
            "Accountant" => Color.Info,
            "Teacher" => Color.Success,
            "Staff" => Color.Secondary,
            _ => Color.Default
        };
    }
}