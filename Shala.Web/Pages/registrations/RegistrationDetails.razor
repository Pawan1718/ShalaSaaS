@page "/student/registrations/details/{Id:int}"

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Responses.Registration
@using Shala.Web.Components.Dialogs
@using Shala.Web.Repositories.Registration

@inject IRegistrationWebRepository Repo
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

@layout Components.Layouts.TenantMainLayout

<PageTitle>Registration Details</PageTitle>

@if (_loading)
{
    <MudPaper Class="pa-6 d-flex justify-center">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
    </MudPaper>
}
else if (_model is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
        Registration not found.
    </MudAlert>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="pa-4">
            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Wrap="Wrap.Wrap">

                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Class="fw-bold">
                        Registration Details
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_model.RegistrationNo
                    </MudText>
                </MudStack>

                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="BackToList">
                        Back
                    </MudButton>

                    @if (HasReceipt)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.ReceiptLong"
                                   OnClick="ViewReceipt">
                            Receipt
                        </MudButton>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="EditAsync">
                        Edit
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-3">
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string"
                         Color="@(_model.FeePaid ? Color.Success : Color.Warning)"
                         Variant="Variant.Filled">
                    @(_model.FeePaid ? "Fee Paid" : "Fee Pending")
                </MudChip>

                <MudChip T="string"
                         Color="@GetStatusColor(_model.Status)"
                         Variant="Variant.Outlined">
                    @DisplayOrDash(_model.Status)
                </MudChip>
            </MudStack>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Class="fw-semibold mb-3">
                        Basic Details
                    </MudText>

                    @InfoRow("Registration No", _model.RegistrationNo)
                    @InfoRow("Registration Date", FormatDate(_model.RegistrationDate))
                    @InfoRow("Student Name", _model.FullName)
                    @InfoRow("DOB", FormatDate(_model.DateOfBirth))
                    @InfoRow("Gender", _model.Gender)
                    @InfoRow("Class", _model.ClassDisplay)
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.subtitle1" Class="fw-semibold mb-3">
                        Guardian Details
                    </MudText>

                    @InfoRow("Guardian Name", _model.GuardianName)
                    @InfoRow("Phone", _model.Phone)
                    @InfoRow("Address", _model.Address)
                    @InfoRow("Note", _model.Note)
                </MudPaper>
            </MudItem>

            @if (_model.StudentId.HasValue || _model.StudentAdmissionId.HasValue || _model.ConvertedOn.HasValue)
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.subtitle1" Class="fw-semibold mb-3">
                            Conversion Details
                        </MudText>

                        @InfoRow("Student Id", _model.StudentId?.ToString())
                        @InfoRow("Admission Id", _model.StudentAdmissionId?.ToString())
                        @InfoRow("Converted On", FormatDateTime(_model.ConvertedOn))
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudStack>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private RegistrationDto? _model;

    private bool HasReceipt => _model?.LatestReceiptId.GetValueOrDefault() > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _model = await Repo.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/student/registrations");
    }

    private void ViewReceipt()
    {
        if (HasReceipt)
            Navigation.NavigateTo($"/student/registrations/receipt/{_model!.LatestReceiptId!.Value}");
    }

    private async Task EditAsync()
    {
        if (_model is null)
            return;

        var parameters = new DialogParameters
        {
            ["Model"] = _model
        };

        var dialog = await Dialog.ShowAsync<RegistrationForm>("Edit Registration", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadAsync();
    }

    private RenderFragment InfoRow(string label, string? value) => @<MudText>
        <b>@label:</b> @DisplayOrDash(value)
    </MudText>;

    private static string DisplayOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(DateTime? date)
        => date.HasValue ? date.Value.ToString("dd MMM yyyy") : "-";

    private static string FormatDate(DateTime date)
        => date == default ? "-" : date.ToString("dd MMM yyyy");

    private static string FormatDateTime(DateTime? date)
        => date.HasValue ? date.Value.ToString("dd MMM yyyy hh:mm tt") : "-";

    private static Color GetStatusColor(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "pending" => Color.Warning,
            "confirmed" => Color.Info,
            "converted" => Color.Success,
            "rejected" => Color.Error,
            "cancelled" => Color.Error,
            _ => Color.Default
        };
    }
}