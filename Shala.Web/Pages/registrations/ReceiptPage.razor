@page "/student/registrations/receipt/{ReceiptId:int}"

@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using MudBlazor
@using Shala.Shared.Responses.Registration
@using Shala.Shared.Responses.Settings
@using Shala.Web.Components.Receipts
@using Shala.Web.Repositories.Registration
@using Shala.Web.Repositories.Settings

@inject IRegistrationWebRepository ReceiptRepo
@inject IBranchDocumentProfileWebRepository ProfileRepo
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Registration Receipt</PageTitle>

@if (_loading)
{
    <MudPaper Class="receipt-page-state pa-8">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Loading receipt...</MudText>
        </MudStack>
    </MudPaper>
}
else if (_receipt is null)
{
    <MudPaper Class="receipt-page-state pa-8">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">
            Receipt not found.
        </MudAlert>
    </MudPaper>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
        <MudStack Spacing="3">

            <MudPaper Class="receipt-toolbar pa-3" Elevation="1">
                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center"
                          Wrap="Wrap.Wrap"
                          Spacing="2">

                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h5" Class="fw-bold">
                            @GetReceiptTitle()
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Receipt No: @DisplayOrDash(_receipt.ReceiptNo)
                        </MudText>
                    </MudStack>

                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="BackToRegistrations">
                            Back
                        </MudButton>

                        @if (CanPrintReceipt())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Print"
                                       OnClick="PrintAsync">
                                Print
                            </MudButton>
                        }

                        @if (CanDownloadReceipt())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                       OnClick="DownloadPdfAsync">
                                PDF
                            </MudButton>
                        }

                        @if (!string.IsNullOrWhiteSpace(_receipt.Phone))
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Share"
                                       OnClick="SendWhatsAppAsync">
                                WhatsApp
                            </MudButton>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>

            <RegistrationReceiptCanvas TargetId="registration-receipt"
                                       Receipt="_receipt"
                                       Profile="_profile"
                                       Mode="ReceiptCanvasMode.DualA4" />
        </MudStack>
    </MudContainer>
}

@code {
    [Parameter] public int ReceiptId { get; set; }

    [SupplyParameterFromQuery(Name = "action")]
    public string? Action { get; set; }

    private bool _loading = true;
    private bool _actionHandled;
    private RegistrationReceiptResponse? _receipt;
    private BranchDocumentProfileResponse? _profile;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            var receiptTask = ReceiptRepo.GetReceiptAsync(ReceiptId);
            var profileTask = ProfileRepo.GetAsync();

            await Task.WhenAll(receiptTask, profileTask);

            _receipt = receiptTask.Result;
            _profile = profileTask.Result;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loading || _receipt is null || _actionHandled)
            return;

        if (string.Equals(Action, "print", StringComparison.OrdinalIgnoreCase) && CanPrintReceipt())
        {
            _actionHandled = true;
            await JS.InvokeVoidAsync("registrationReceipt.printPage");
        }
        else if (string.Equals(Action, "pdf", StringComparison.OrdinalIgnoreCase) && CanDownloadReceipt())
        {
            _actionHandled = true;
            await JS.InvokeVoidAsync("registrationReceipt.downloadPdf", GetSafeFileName());
        }
    }

    private bool CanPrintReceipt()
        => _profile?.AllowPrintReceipt ?? true;

    private bool CanDownloadReceipt()
        => _profile?.AllowDownloadReceipt ?? true;

    private string GetReceiptTitle()
        => string.IsNullOrWhiteSpace(_profile?.ReceiptTitle) ? "Registration Receipt" : _profile!.ReceiptTitle!;

    private async Task PrintAsync()
        => await JS.InvokeVoidAsync("registrationReceipt.printPage");

    private async Task DownloadPdfAsync()
        => await JS.InvokeVoidAsync("registrationReceipt.downloadPdf", GetSafeFileName());

    private async Task SendWhatsAppAsync()
    {
        if (_receipt is null || string.IsNullOrWhiteSpace(_receipt.Phone))
            return;

        var url = Navigation.ToAbsoluteUri($"/student/registrations/receipt/{ReceiptId}");

        var msg =
            $"Receipt No: {_receipt.ReceiptNo}\n" +
            $"Student: {_receipt.StudentName}\n" +
            $"Amount: ₹ {GetTotalAmount():0.##}\n" +
            $"Date: {FormatDate(_receipt.ReceiptDate)}\n" +
            $"View: {url}";

        await JS.InvokeVoidAsync("registrationReceipt.sendWhatsApp", _receipt.Phone, msg);
    }

    private void BackToRegistrations()
        => Navigation.NavigateTo("/student/registrations");

    private decimal GetTotalAmount()
    {
        if (_receipt is null)
            return 0m;

        if (_receipt.TotalAmount > 0)
            return _receipt.TotalAmount;

        return _receipt.Lines?.Sum(x => x.Amount) ?? 0m;
    }

    private string GetSafeFileName()
    {
        var no = string.IsNullOrWhiteSpace(_receipt?.ReceiptNo) ? $"receipt-{ReceiptId}" : _receipt!.ReceiptNo;
        return no.Replace("/", "-").Replace("\\", "-").Replace(" ", "-");
    }

    private static string DisplayOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(DateTime value)
        => value == default ? "-" : value.ToString("dd MMM yyyy");
}