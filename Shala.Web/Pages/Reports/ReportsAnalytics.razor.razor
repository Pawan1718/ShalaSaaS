    private RenderFragment RenderLedger() => @<MudPaper Class="pa-3 report-table-card" Elevation="1">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">For best results, enter Student Id in filter before loading ledger.</MudAlert>
        <MudTable T="StudentFeeLedgerReportResponse" Items="_ledger.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent><MudTh>Date</MudTh><MudTh>Type</MudTh><MudTh>Reference</MudTh><MudTh Style="text-align:right">Debit</MudTh><MudTh Style="text-align:right">Credit</MudTh><MudTh Style="text-align:right">Balance</MudTh><MudTh>Remarks</MudTh></HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.EntryDate.ToString("dd-MMM-yyyy")</MudTd>
                <MudTd>@row.EntryType</MudTd>
                <MudTd>@row.ReferenceNo</MudTd>
                <MudTd Style="text-align:right">@Money(row.DebitAmount)</MudTd>
                <MudTd Style="text-align:right">@Money(row.CreditAmount)</MudTd>
                <MudTd Style="text-align:right">@Money(row.RunningBalance)</MudTd>
                <MudTd>@row.Remarks</MudTd>
            </RowTemplate>
        </MudTable>
        <ReportPager TotalCount="_ledger.TotalCount" PageNumber="_request.PageNumber" PageSize="_request.PageSize" PageChanged="OnPageChangedAsync" />
    </MudPaper>;

    private RenderFragment RenderReceipts() => @<MudPaper Class="pa-3 report-table-card" Elevation="1">
        <MudTable T="ReceiptRegisterReportResponse" Items="_receipts.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent><MudTh>Receipt</MudTh><MudTh>Date</MudTh><MudTh>Student</MudTh><MudTh>Mode</MudTh><MudTh Style="text-align:right">Amount</MudTh><MudTh>Status</MudTh></HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.ReceiptNo</MudTd>
                <MudTd>@row.ReceiptDate.ToString("dd-MMM-yyyy")</MudTd>
                <MudTd><b>@row.StudentName</b><br /><small>@row.AdmissionNo</small></MudTd>
                <MudTd>@row.PaymentMode</MudTd>
                <MudTd Style="text-align:right">@Money(row.TotalAmount)</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@(row.IsCancelled ? Color.Error : Color.Success)" Variant="Variant.Outlined">@(row.IsCancelled ? "Cancelled" : "Active")</MudChip></MudTd>
            </RowTemplate>
        </MudTable>
        <ReportPager TotalCount="_receipts.TotalCount" PageNumber="_request.PageNumber" PageSize="_request.PageSize" PageChanged="OnPageChangedAsync" />
    </MudPaper>;

    private RenderFragment RenderStrength() => @<MudPaper Class="pa-3 report-table-card" Elevation="1">
        <MudTable T="AcademicStrengthReportResponse" Items="_strength.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent><MudTh>Academic Year</MudTh><MudTh>Class</MudTh><MudTh>Section</MudTh><MudTh Style="text-align:right">Students</MudTh></HeaderContent>
            <RowTemplate Context="row"><MudTd>@row.AcademicYearName</MudTd><MudTd>@row.ClassName</MudTd><MudTd>@row.SectionName</MudTd><MudTd Style="text-align:right">@row.StudentCount</MudTd></RowTemplate>
        </MudTable>
        <ReportPager TotalCount="_strength.TotalCount" PageNumber="_request.PageNumber" PageSize="_request.PageSize" PageChanged="OnPageChangedAsync" />
    </MudPaper>;

    private RenderFragment RenderDocuments() => @<MudPaper Class="pa-3 report-table-card" Elevation="1">
        <MudTable T="PendingDocumentReportResponse" Items="_documents.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent><MudTh>Student</MudTh><MudTh>Academic Year</MudTh><MudTh>Class</MudTh><MudTh Style="text-align:right">Required</MudTh><MudTh Style="text-align:right">Received</MudTh><MudTh Style="text-align:right">Pending</MudTh></HeaderContent>
            <RowTemplate Context="row">
                <MudTd><b>@row.StudentName</b><br /><small>@row.AdmissionNo</small></MudTd>
                <MudTd>@row.AcademicYearName</MudTd>
                <MudTd>@row.ClassName @row.SectionName</MudTd>
                <MudTd Style="text-align:right">@row.RequiredDocumentCount</MudTd>
                <MudTd Style="text-align:right">@row.ReceivedDocumentCount</MudTd>
                <MudTd Style="text-align:right"><MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@row.PendingDocumentCount</MudChip></MudTd>
            </RowTemplate>
        </MudTable>
        <ReportPager TotalCount="_documents.TotalCount" PageNumber="_request.PageNumber" PageSize="_request.PageSize" PageChanged="OnPageChangedAsync" />
    </MudPaper>;

    private RenderFragment RenderStudentDobAge() => @<MudPaper Class="pa-3 report-table-card" Elevation="1">
    <MudTable T="StudentDobAgeReportResponse"
              Items="_studentDobAge.Items"
              Dense="true"
              Hover="true"
              Striped="true"
              Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Student</MudTh>
            <MudTh>Class</MudTh>
            <MudTh>Roll</MudTh>
            <MudTh>DOB</MudTh>
            <MudTh>Age</MudTh>
        </HeaderContent>
        <RowTemplate Context="row">
            <MudTd>
                <b>@row.StudentName</b><br />
                <small>@row.AdmissionNo</small>
            </MudTd>
            <MudTd>@row.ClassName @row.SectionName</MudTd>
            <MudTd>@row.RollNo</MudTd>
            <MudTd>@(row.DateOfBirth?.ToString("dd-MMM-yyyy") ?? "-")</MudTd>
            <MudTd>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@(row.DateOfBirth.HasValue ? Color.Success : Color.Default)"
                         Variant="Variant.Outlined">
                    @row.AgeText
                </MudChip>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <ReportPager TotalCount="_studentDobAge.TotalCount"
                 PageNumber="_request.PageNumber"
                 PageSize="_request.PageSize"
                 PageChanged="OnPageChangedAsync" />
</MudPaper>;
    private static string Money(decimal amount) => amount.ToString("N2");
