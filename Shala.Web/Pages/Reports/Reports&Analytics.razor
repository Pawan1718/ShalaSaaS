@page "/tenant/reports"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Common
@using Shala.Shared.Requests.Reports
@using Shala.Shared.Responses.Reports
@using Shala.Web.Repositories.Reports
@using Shala.Web.Services.Http

@inject IReportsWebRepository ReportsRepo
@inject ISnackbar Snackbar

<PageTitle>Reports & Analytics</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-5 pa-md-6" Elevation="2" Style="border-radius:20px; background:linear-gradient(135deg, rgba(25,118,210,.10), rgba(76,175,80,.10));">
        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
            <MudItem xs="12" md="8">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.QueryStats" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h4">Reports & Analytics</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Student, admission, fees, academic strength and document reports.
                        </MudText>
                    </div>
                </MudStack>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Wrap="Wrap.Wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="LoadCurrentReportAsync">
                        Apply
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ResetAsync">
                        Reset
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@_error</MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="3">
            <MudPaper Class="pa-3" Elevation="1" Style="border-radius:18px;">
                <MudStack Spacing="1">
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Dashboard)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Dashboard" OnClick="() => ChangeTabAsync(ReportTab.Dashboard)">Dashboard</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Students)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Groups" OnClick="() => ChangeTabAsync(ReportTab.Students)">Student Master</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Admissions)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AppRegistration" OnClick="() => ChangeTabAsync(ReportTab.Admissions)">Admission Register</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Collection)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Payments" OnClick="() => ChangeTabAsync(ReportTab.Collection)">Fee Collection</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Outstanding)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.WarningAmber" OnClick="() => ChangeTabAsync(ReportTab.Outstanding)">Outstanding</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Receipts)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ReceiptLong" OnClick="() => ChangeTabAsync(ReportTab.Receipts)">Receipt Register</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Strength)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Class" OnClick="() => ChangeTabAsync(ReportTab.Strength)">Class Strength</MudButton>
                    <MudButton FullWidth="true" Variant="@ButtonVariant(ReportTab.Documents)" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FolderCopy" OnClick="() => ChangeTabAsync(ReportTab.Documents)">Pending Documents</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="9">
            <MudStack Spacing="3">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius:18px;">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudTextField T="string" Label="Search" Placeholder="Name / admission no / receipt no"
                                          @bind-Value="_request.SearchText"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudDatePicker Label="From Date" @bind-Date="_request.FromDate"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudDatePicker Label="To Date" @bind-Date="_request.ToDate"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                        </MudItem>

                        <MudItem xs="12" md="2">
                            <MudSelect T="int" Label="Rows" Value="_request.PageSize" ValueChanged="OnPageSizeChangedAsync"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="int" Value="10">10</MudSelectItem>
                                <MudSelectItem T="int" Value="25">25</MudSelectItem>
                                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                                <MudSelectItem T="int" Value="100">100</MudSelectItem>
                                <MudSelectItem T="int" Value="-1">All</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @if (_loading)
                {
                    <MudPaper Class="pa-8 d-flex justify-center" Elevation="0">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                            <MudText Color="Color.Secondary">Loading report...</MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    @switch (_activeTab)
                    {
                        case ReportTab.Dashboard:
                            @RenderDashboard()
                            break;
                        case ReportTab.Students:
                            @RenderStudents()
                            break;
                        case ReportTab.Admissions:
                            @RenderAdmissions()
                            break;
                        case ReportTab.Collection:
                            @RenderCollection()
                            break;
                        case ReportTab.Outstanding:
                            @RenderOutstanding()
                            break;
                        case ReportTab.Receipts:
                            @RenderReceipts()
                            break;
                        case ReportTab.Strength:
                            @RenderStrength()
                            break;
                        case ReportTab.Documents:
                            @RenderDocuments()
                            break;
                    }
                }
            </MudStack>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private enum ReportTab
    {
        Dashboard,
        Students,
        Admissions,
        Collection,
        Outstanding,
        Receipts,
        Strength,
        Documents
    }

    private ReportTab _activeTab = ReportTab.Dashboard;
    private ReportFilterRequest _request = new() { PageNumber = 1, PageSize = 10 };
    private bool _loading;
    private string? _error;

    private ReportsDashboardResponse? _dashboard;
    private PagedResult<StudentMasterReportResponse> _students = Empty<StudentMasterReportResponse>();
    private PagedResult<AdmissionRegisterReportResponse> _admissions = Empty<AdmissionRegisterReportResponse>();
    private PagedResult<FeeCollectionReportResponse> _collection = Empty<FeeCollectionReportResponse>();
    private PagedResult<OutstandingFeeReportResponse> _outstanding = Empty<OutstandingFeeReportResponse>();
    private PagedResult<ReceiptRegisterReportResponse> _receipts = Empty<ReceiptRegisterReportResponse>();
    private PagedResult<AcademicStrengthReportResponse> _strength = Empty<AcademicStrengthReportResponse>();
    private PagedResult<PendingDocumentReportResponse> _documents = Empty<PendingDocumentReportResponse>();

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentReportAsync();
    }

    private static PagedResult<T> Empty<T>() => new()
    {
        Items = new List<T>(),
        PageNumber = 1,
        PageSize = 10,
        TotalCount = 0
    };

    private Variant ButtonVariant(ReportTab tab)
        => _activeTab == tab ? Variant.Filled : Variant.Text;

    private async Task ChangeTabAsync(ReportTab tab)
    {
        _activeTab = tab;
        _request.PageNumber = 1;
        await LoadCurrentReportAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        _request.PageSize = pageSize;
        _request.PageNumber = 1;
        await LoadCurrentReportAsync();
    }

    private async Task ResetAsync()
    {
        _request = new ReportFilterRequest { PageNumber = 1, PageSize = 10 };
        await LoadCurrentReportAsync();
    }

    private async Task LoadCurrentReportAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            switch (_activeTab)
            {
                case ReportTab.Dashboard:
                    _dashboard = Extract(await ReportsRepo.GetDashboardAsync(_request), new ReportsDashboardResponse());
                    break;

                case ReportTab.Students:
                    _students = Extract(await ReportsRepo.GetStudentMasterAsync(_request), Empty<StudentMasterReportResponse>());
                    break;

                case ReportTab.Admissions:
                    _admissions = Extract(await ReportsRepo.GetAdmissionRegisterAsync(_request), Empty<AdmissionRegisterReportResponse>());
                    break;

                case ReportTab.Collection:
                    _collection = Extract(await ReportsRepo.GetFeeCollectionAsync(_request), Empty<FeeCollectionReportResponse>());
                    break;

                case ReportTab.Outstanding:
                    _outstanding = Extract(await ReportsRepo.GetOutstandingFeesAsync(_request), Empty<OutstandingFeeReportResponse>());
                    break;

                case ReportTab.Receipts:
                    _receipts = Extract(await ReportsRepo.GetReceiptRegisterAsync(_request), Empty<ReceiptRegisterReportResponse>());
                    break;

                case ReportTab.Strength:
                    _strength = Extract(await ReportsRepo.GetAcademicStrengthAsync(_request), Empty<AcademicStrengthReportResponse>());
                    break;

                case ReportTab.Documents:
                    _documents = Extract(await ReportsRepo.GetPendingDocumentsAsync(_request), Empty<PendingDocumentReportResponse>());
                    break;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private T Extract<T>(ServerResponseHelper<T> response, T fallback)
    {
        if (response.IsSuccess && response.ServerResponse is not null)
            return response.ServerResponse;

        var message = string.IsNullOrWhiteSpace(response.Message)
            ? "Unable to load report."
            : response.Message;

        _error = message;
        Snackbar.Add(message, Severity.Error);
        return fallback;
    }

    private RenderFragment RenderDashboard() => @<MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Total Students" Value="@((_dashboard?.TotalStudents ?? 0).ToString("N0"))" Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Active Students" Value="@((_dashboard?.ActiveStudents ?? 0).ToString("N0"))" Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Today Collection" Value="@Money(_dashboard?.TodayCollection ?? 0)" Icon="@Icons.Material.Filled.Payments" Color="Color.Info" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Outstanding" Value="@Money(_dashboard?.TotalOutstanding ?? 0)" Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Error" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Today Admissions" Value="@((_dashboard?.TodayAdmissions ?? 0).ToString("N0"))" Icon="@Icons.Material.Filled.AppRegistration" Color="Color.Warning" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Month Collection" Value="@Money(_dashboard?.MonthCollection ?? 0)" Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="Pending Documents" Value="@((_dashboard?.PendingDocuments ?? 0).ToString("N0"))" Icon="@Icons.Material.Filled.FolderCopy" Color="Color.Secondary" />
        </MudItem>
    </MudGrid>;

    private RenderFragment RenderStudents() => @<ReportCard Title="Student Master List" Total="@_students.TotalCount">
        <MudTable T="StudentMasterReportResponse" Items="_students.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Student</MudTh>
                <MudTh>Class</MudTh>
                <MudTh>Guardian</MudTh>
                <MudTh>Mobile</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd DataLabel="Student">
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd DataLabel="Class">@row.ClassName @row.SectionName</MudTd>
                <MudTd DataLabel="Guardian">@row.GuardianName</MudTd>
                <MudTd DataLabel="Mobile">@row.Mobile</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @row.StudentStatus
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderAdmissions() => @<ReportCard Title="Admission Register" Total="@_admissions.TotalCount">
        <MudTable T="AdmissionRegisterReportResponse" Items="_admissions.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Student</MudTh>
                <MudTh>Class</MudTh>
                <MudTh>Academic Year</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.AdmissionDate.ToString("dd-MMM-yyyy")</MudTd>
                <MudTd>
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd>@row.ClassName @row.SectionName</MudTd>
                <MudTd>@row.AcademicYearName</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @row.AdmissionStatus
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderCollection() => @<ReportCard Title="Fee Collection" Total="@_collection.TotalCount">
        <MudTable T="FeeCollectionReportResponse" Items="_collection.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Receipt</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Student</MudTh>
                <MudTh>Mode</MudTh>
                <MudTh Align="right">Amount</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.ReceiptNo</MudTd>
                <MudTd>@row.ReceiptDate.ToString("dd-MMM-yyyy")</MudTd>
                <MudTd>
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd>@row.PaymentMode</MudTd>
                <MudTd Align="right">@Money(row.Amount)</MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderOutstanding() => @<ReportCard Title="Outstanding / Defaulters" Total="@_outstanding.TotalCount">
        <MudTable T="OutstandingFeeReportResponse" Items="_outstanding.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Student</MudTh>
                <MudTh>Class</MudTh>
                <MudTh Align="right">Net Amount</MudTh>
                <MudTh Align="right">Paid</MudTh>
                <MudTh Align="right">Balance</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd>@row.ClassName @row.SectionName</MudTd>
                <MudTd Align="right">@Money(row.NetAmount)</MudTd>
                <MudTd Align="right">@Money(row.TotalPaid)</MudTd>
                <MudTd Align="right">
                    <MudText Color="Color.Error">@Money(row.Balance)</MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderReceipts() => @<ReportCard Title="Receipt Register" Total="@_receipts.TotalCount">
        <MudTable T="ReceiptRegisterReportResponse" Items="_receipts.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Receipt</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Student</MudTh>
                <MudTh>Mode</MudTh>
                <MudTh Align="right">Amount</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.ReceiptNo</MudTd>
                <MudTd>@row.ReceiptDate.ToString("dd-MMM-yyyy")</MudTd>
                <MudTd>
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd>@row.PaymentMode</MudTd>
                <MudTd Align="right">@Money(row.TotalAmount)</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(row.IsCancelled ? Color.Error : Color.Success)" Variant="Variant.Outlined">
                        @(row.IsCancelled ? "Cancelled" : "Active")
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderStrength() => @<ReportCard Title="Class / Section Strength" Total="@_strength.TotalCount">
        <MudTable T="AcademicStrengthReportResponse" Items="_strength.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Class</MudTh>
                <MudTh>Section</MudTh>
                <MudTh Align="right">Students</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.ClassName</MudTd>
                <MudTd>@row.SectionName</MudTd>
                <MudTd Align="right">@row.StudentCount</MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private RenderFragment RenderDocuments() => @<ReportCard Title="Pending Documents" Total="@_documents.TotalCount">
        <MudTable T="PendingDocumentReportResponse" Items="_documents.Items" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Student</MudTh>
                <MudTh>Class</MudTh>
                <MudTh Align="right">Pending</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>
                    <b>@row.StudentName</b><br />
                    <small>@row.AdmissionNo</small>
                </MudTd>
                <MudTd>@row.ClassName @row.SectionName</MudTd>
                <MudTd Align="right">
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                        @row.PendingDocumentCount
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </ReportCard>;

    private static string Money(decimal amount) => amount.ToString("N2");
}