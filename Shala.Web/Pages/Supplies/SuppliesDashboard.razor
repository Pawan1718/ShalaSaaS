


@page "/tenant/supplies"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Responses.Supplies
@using Shala.Web.Components.Common
@using Shala.Web.Repositories.Supplies

@inject ISuppliesWebRepository SuppliesRepo
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Student Supplies</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppDataState Loading="@_loading"
                  Error="@_error"
                  Empty="false">
        <ChildContent>

            <AppPageHeader Title="Student Supplies"
                           Subtitle="Quick actions for stock, issue and due collection">
                <Actions>
                    <AppButton StartIcon="@Icons.Material.Filled.ShoppingCart"
                               OnClick="@((MouseEventArgs _) => GoToGive())">
                        Give Items
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Inventory2"
                               OnClick="@((MouseEventArgs _) => GoToAddStock())">
                        Add Stock
                    </AppButton>

                    <AppButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Payments"
                               OnClick="@((MouseEventArgs _) => GoToCollectDue())">
                        Collect Due
                    </AppButton>
                </Actions>
            </AppPageHeader>

            <!-- Stats -->
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" sm="6" md="3">
                    <AppStatCard Label="Today Given Items"
                                 Value="@_dashboard.TodayIssueCount.ToString()"
                                 Icon="@Icons.Material.Filled.ShoppingBag" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <AppStatCard Label="Today Collection"
                                 Value="@_dashboard.TodayCollection.ToString("N2")"
                                 Icon="@Icons.Material.Filled.Payments"
                                 Color="Color.Success" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <AppStatCard Label="Pending Due"
                                 Value="@_dashboard.PendingDue.ToString("N2")"
                                 Icon="@Icons.Material.Filled.PendingActions"
                                 Color="Color.Warning" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <AppStatCard Label="Low Stock Items"
                                 Value="@_dashboard.LowStockItemCount.ToString()"
                                 Icon="@Icons.Material.Filled.Inventory"
                                 Color="Color.Error" />
                </MudItem>
            </MudGrid>

            <!-- Quick Action Cards -->
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <AppCard Class="supply-action-card">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" />
                            <MudText Typo="Typo.h6">Give Items</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Issue items to students and generate bill
                            </MudText>

                            <AppButton FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.ArrowForward"
                                       OnClick="@((MouseEventArgs _) => GoToGive())">
                                Open
                            </AppButton>
                        </MudStack>
                    </AppCard>
                </MudItem>

                <MudItem xs="12" md="4">
                    <AppCard Class="supply-action-card">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" />
                            <MudText Typo="Typo.h6">Add Stock</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Add incoming stock items
                            </MudText>

                            <AppButton FullWidth="true"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.ArrowForward"
                                       OnClick="@((MouseEventArgs _) => GoToAddStock())">
                                Open
                            </AppButton>
                        </MudStack>
                    </AppCard>
                </MudItem>

                <MudItem xs="12" md="4">
                    <AppCard Class="supply-action-card">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" />
                            <MudText Typo="Typo.h6">Collect Due</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Collect pending payments from supply bills
                            </MudText>

                            <AppButton FullWidth="true"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.ArrowForward"
                                       OnClick="@((MouseEventArgs _) => GoToCollectDue())">
                                Open
                            </AppButton>
                        </MudStack>
                    </AppCard>
                </MudItem>
            </MudGrid>

        </ChildContent>
    </AppDataState>
</AppPageShell>

@code {
    private bool _loading = true;
    private string? _error;

    private SupplyDashboardResponse _dashboard = new();

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", "/tenant/dashboard"),
        new("Supplies", null, true)
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dashboard = await SuppliesRepo.GetDashboardAsync() ?? new();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToGive() => Nav.NavigateTo("/tenant/supplies/give");
    private void GoToAddStock() => Nav.NavigateTo("/tenant/supplies/add-stock");
    private void GoToCollectDue() => Nav.NavigateTo("/tenant/supplies/collect-due");
}