@page "/tenant/supplies/items"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using MudBlazor
@using Shala.Shared.Requests.Supplies
@using Shala.Shared.Responses.Supplies
@using Shala.Web.Repositories.Supplies

@inject ISuppliesWebRepository SuppliesRepo
@inject ISnackbar Snackbar

<PageTitle>Supply Items</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4" Style="border-radius:18px;">
        <MudText Typo="Typo.h5">Items Setup</MudText>
        <MudText Color="Color.Secondary">Add items once, then use them while giving supplies.</MudText>
    </MudPaper>

    <MudPaper Class="pa-4" Style="border-radius:18px;">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField Label="Item Name" @bind-Value="_form.Name" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField Label="Code" @bind-Value="_form.Code" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="decimal" Label="Sale Price" @bind-Value="_form.SalePrice" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="decimal" Label="Opening Stock" @bind-Value="_form.OpeningStock" Variant="Variant.Outlined" Disabled="_editId.HasValue" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField T="decimal" Label="Minimum Stock" @bind-Value="_form.MinimumStock" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="1" Class="d-flex align-center">
                <MudSwitch T="bool" Label="Active" @bind-Checked="_form.IsActive" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Spacing="1" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving" OnClick="SaveAsync">
                @(_editId.HasValue ? "Update Item" : "Add Item")
            </MudButton>
            @if (_editId.HasValue)
            {
                <MudButton Variant="Variant.Outlined" OnClick="ResetForm">Cancel</MudButton>
            }
        </MudStack>
    </MudPaper>

    <MudTable Items="_items" Loading="_loading" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Code</MudTh>
            <MudTh>Price</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Minimum</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Action</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Code</MudTd>
            <MudTd>₹@context.SalePrice.ToString("N2")</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsLowStock ? Color.Error : Color.Success)" Size="Size.Small">
                    @context.CurrentStock
                </MudChip>
            </MudTd>
            <MudTd>@context.MinimumStock</MudTd>
            <MudTd>@(context.IsActive ? "Active" : "Inactive")</MudTd>
            <MudTd>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => Edit(context))">Edit</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private bool _loading = true;
    private bool _saving;
    private int? _editId;
    private List<SupplyItemResponse> _items = [];
    private CreateSupplyItemRequest _form = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try { _items = await SuppliesRepo.GetItemsAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Item name is required.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            if (_editId.HasValue)
            {
                await SuppliesRepo.UpdateItemAsync(_editId.Value, new UpdateSupplyItemRequest
                {
                    Name = _form.Name,
                    Code = _form.Code,
                    Description = _form.Description,
                    SalePrice = _form.SalePrice,
                    MinimumStock = _form.MinimumStock,
                    IsActive = _form.IsActive
                });
                Snackbar.Add("Item updated.", Severity.Success);
            }
            else
            {
                await SuppliesRepo.CreateItemAsync(_form);
                Snackbar.Add("Item added.", Severity.Success);
            }

            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private void Edit(SupplyItemResponse item)
    {
        _editId = item.Id;
        _form = new CreateSupplyItemRequest
        {
            Name = item.Name,
            Code = item.Code,
            Description = item.Description,
            SalePrice = item.SalePrice,
            OpeningStock = 0,
            MinimumStock = item.MinimumStock,
            IsActive = item.IsActive
        };
    }

    private void ResetForm()
    {
        _editId = null;
        _form = new CreateSupplyItemRequest { IsActive = true };
    }
}