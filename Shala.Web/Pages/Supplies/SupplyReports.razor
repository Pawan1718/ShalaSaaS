


    @page "/tenant/supplies/reports"
@layout Shala.Web.Components.Layouts.TenantMainLayout

@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Shala.Shared.Requests.Supplies
@using Shala.Shared.Responses.Supplies
@using Shala.Web.Components.Common
@using Shala.Web.Repositories.Supplies

@inject ISuppliesWebRepository SuppliesRepo
@inject ISnackbar Snackbar

<PageTitle>Supply Reports</PageTitle>

<AppPageShell>
    <AppBreadcrumbs Items="_breadcrumbs" />

    <AppPageHeader Title="Supply Reports"
                   Subtitle="Simple reports for stock, low stock, dues and stock movement">
        <Actions>
            <AppButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@_loading"
                       OnClick="@(async _ => await LoadAsync())">
                Reload
            </AppButton>
        </Actions>
    </AppPageHeader>

    <AppDataState Loading="@_loading"
                  Error="@_error"
                  Empty="false">
        <ChildContent>
            <MudTabs Rounded="true" Border="true">
                <MudTabPanel Text="Item Stock" Icon="@Icons.Material.Filled.Inventory2">
                    <AppTableCard TItem="SupplyItemResponse"
                                  Class="mt-4"
                                  Title="Item Stock"
                                  Subtitle="@($"{_items.Count} item(s)")"
                                  IsLoading="false"
                                  IsEmpty="@(!_items.Any())"
                                  EmptyTitle="No items found"
                                  EmptyMessage="Create supply items to see stock report.">
                        <ChildContent>
                            <MudTable T="SupplyItemResponse"
                                      Items="@_items"
                                      Dense="true"
                                      Hover="true"
                                      Striped="true"
                                      Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Item</MudTh>
                                    <MudTh Align="right">Price</MudTh>
                                    <MudTh Align="right">Stock</MudTh>
                                    <MudTh Align="right">Minimum</MudTh>
                                </HeaderContent>

                                <RowTemplate>
                                    <MudTd DataLabel="Item">@context.Name</MudTd>
                                    <MudTd DataLabel="Price" Align="right">₹@context.SalePrice.ToString("N2")</MudTd>
                                    <MudTd DataLabel="Stock" Align="right">
                                        <MudChip T="string"
                                                 Color="@(context.IsLowStock ? Color.Error : Color.Success)"
                                                 Size="Size.Small">
                                            @context.CurrentStock
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Minimum" Align="right">@context.MinimumStock</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </ChildContent>
                    </AppTableCard>
                </MudTabPanel>

                <MudTabPanel Text="Low Stock" Icon="@Icons.Material.Filled.Warning">
                    <AppTableCard TItem="SupplyItemResponse"
                                  Class="mt-4"
                                  Title="Low Stock"
                                  Subtitle="@($"{_lowStock.Count} item(s)")"
                                  IsLoading="false"
                                  IsEmpty="@(!_lowStock.Any())"
                                  EmptyTitle="No low stock items"
                                  EmptyMessage="All items are above minimum stock level.">
                        <ChildContent>
                            <MudTable T="SupplyItemResponse"
                                      Items="@_lowStock"
                                      Dense="true"
                                      Hover="true"
                                      Striped="true"
                                      Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Item</MudTh>
                                    <MudTh Align="right">Stock</MudTh>
                                    <MudTh Align="right">Minimum</MudTh>
                                </HeaderContent>

                                <RowTemplate>
                                    <MudTd DataLabel="Item">@context.Name</MudTd>
                                    <MudTd DataLabel="Stock" Align="right">
                                        <MudText Color="Color.Error">@context.CurrentStock</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Minimum" Align="right">@context.MinimumStock</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </ChildContent>
                    </AppTableCard>
                </MudTabPanel>

                <MudTabPanel Text="Pending Due" Icon="@Icons.Material.Filled.PendingActions">
                    <AppTableCard TItem="PendingSupplyDueResponse"
                                  Class="mt-4"
                                  Title="Pending Due"
                                  Subtitle="@($"{_dues.Count} bill(s)")"
                                  IsLoading="false"
                                  IsEmpty="@(!_dues.Any())"
                                  EmptyTitle="No pending dues"
                                  EmptyMessage="All supply bills are fully paid.">
                        <ChildContent>
                            <MudTable T="PendingSupplyDueResponse"
                                      Items="@_dues"
                                      Dense="true"
                                      Hover="true"
                                      Striped="true"
                                      Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Bill</MudTh>
                                    <MudTh>Student</MudTh>
                                    <MudTh Align="right">Total</MudTh>
                                    <MudTh Align="right">Paid</MudTh>
                                    <MudTh Align="right">Due</MudTh>
                                </HeaderContent>

                                <RowTemplate>
                                    <MudTd DataLabel="Bill">@context.IssueNo</MudTd>
                                    <MudTd DataLabel="Student">@context.StudentName</MudTd>
                                    <MudTd DataLabel="Total" Align="right">₹@context.TotalAmount.ToString("N2")</MudTd>
                                    <MudTd DataLabel="Paid" Align="right">₹@context.PaidAmount.ToString("N2")</MudTd>
                                    <MudTd DataLabel="Due" Align="right">
                                        <MudText Color="Color.Warning">₹@context.DueAmount.ToString("N2")</MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </ChildContent>
                    </AppTableCard>
                </MudTabPanel>

                <MudTabPanel Text="Stock History" Icon="@Icons.Material.Filled.History">
                    <AppTableCard TItem="SupplyStockLedgerResponse"
                                  Class="mt-4"
                                  Title="Stock History"
                                  Subtitle="@($"{_stockHistory.Count} movement(s)")"
                                  IsLoading="false"
                                  IsEmpty="@(!_stockHistory.Any())"
                                  EmptyTitle="No stock history found"
                                  EmptyMessage="Stock movements will appear here.">
                        <ChildContent>
                            <MudTable T="SupplyStockLedgerResponse"
                                      Items="@_stockHistory"
                                      Dense="true"
                                      Hover="true"
                                      Striped="true"
                                      Breakpoint="Breakpoint.Sm">
                                <HeaderContent>
                                    <MudTh>Date</MudTh>
                                    <MudTh>Item</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh Align="right">Qty</MudTh>
                                    <MudTh Align="right">Balance</MudTh>
                                    <MudTh>Note</MudTh>
                                </HeaderContent>

                                <RowTemplate>
                                    <MudTd DataLabel="Date">@context.MovementDate.ToString("dd-MMM-yyyy")</MudTd>
                                    <MudTd DataLabel="Item">@context.ItemName</MudTd>
                                    <MudTd DataLabel="Type">@context.MovementType</MudTd>
                                    <MudTd DataLabel="Qty" Align="right">@context.Quantity</MudTd>
                                    <MudTd DataLabel="Balance" Align="right">@context.BalanceAfter</MudTd>
                                    <MudTd DataLabel="Note">@(string.IsNullOrWhiteSpace(context.Remarks) ? "-" : context.Remarks)</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </ChildContent>
                    </AppTableCard>
                </MudTabPanel>
            </MudTabs>
        </ChildContent>
    </AppDataState>
</AppPageShell>

@code {
    private bool _loading = true;
    private string? _error;

    private List<SupplyItemResponse> _items = [];
    private List<SupplyItemResponse> _lowStock = [];
    private List<PendingSupplyDueResponse> _dues = [];
    private List<SupplyStockLedgerResponse> _stockHistory = [];

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", "/tenant/dashboard"),
        new("Supplies", "/tenant/supplies"),
        new("Reports", null, true)
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _items = await SuppliesRepo.GetItemsAsync();
            _lowStock = await SuppliesRepo.GetLowStockAsync();
            _dues = await SuppliesRepo.GetDuesAsync();
            _stockHistory = await SuppliesRepo.GetStockHistoryAsync(new SupplyReportRequest());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}